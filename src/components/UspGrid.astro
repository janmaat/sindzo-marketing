---
// Drie USP's afgeleid uit Marketing-deep-research-report.md:
// 1. Procesfit/regeldruk-reductie (Zorg voor Beter: 18% admin-last via ECD)
// 2. Aantoonbare openheid (FHIR/MedMij/Wegiz)
// 3. Security & compliance (NEN 7510, Cbw-readiness)
// Iconen zijn fijne line-SVG's (one-pager-stijl) in plaats van emoji —
// consistenter, scherper op retina, en kleur-controleerbaar via stroke.
const usps = [
  {
    // Verbonden tandwielen — proces & integratie.
    iconPath: '<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06A2 2 0 1 1 4.21 16.96l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06A2 2 0 1 1 7.04 4.21l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9c.36.36.85.6 1.51.6H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>',
    title: 'Eén proces, minder regeldruk',
    body: 'Dossier, planning, declaratie en kwaliteit in één werkruimte. Eén keer registreren, overal gebruikt — minder dubbele invoer, minder schakelen tussen systemen.',
    link: { label: 'Hoe regeldruk daalt', href: '/oplossing#regeldruk' },
  },
  {
    // Uitwisselings-pijlen — openheid.
    iconPath: '<path d="M7 7h11l-3-3"/><path d="M17 17H6l3 3"/>',
    title: 'Open, niet gevangen',
    body: 'Aantoonbare interoperabiliteit via FHIR, MedMij, Wegiz en eOverdracht. Open API, dataportabiliteit en publieke koppeldocumentatie — geen vendor lock-in.',
    link: { label: 'Bekijk integraties', href: '/integraties' },
  },
  {
    // Schild met vinkje — security & vertrouwen.
    iconPath: '<path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/><path d="M9 12l2 2 4-4"/>',
    title: 'Vertrouwen op tafel',
    body: 'NEN 7510-werkdocument, DPA-template, subverwerkerslijst, logging en incidentproces publiek inzichtelijk — voordat een tender start. Cbw-ready voor 1 juli 2026.',
    link: { label: 'Open Trust Centre', href: '/trust' },
  },
];
---
<section class="container-prose py-20">
  <div class="max-w-2xl">
    <h2 class="font-display text-3xl font-bold tracking-tightish text-ink-900 sm:text-4xl">
      Drie redenen waarom <em class="italic font-semibold text-accent-600">bestuur, CIO én FG samen</em> kiezen voor Sindzo.
    </h2>
    <p class="mt-4 text-ink-700">
      In de Nederlandse zorg sneuvelen leveranciers zelden op functionaliteit, en vaak op
      gebrek aan helderheid over data, security en proceswinst. Wij draaien dat om.
    </p>
  </div>
  <div class="mt-12 grid gap-8 md:grid-cols-3">
    {usps.map((u) => (
      <article class="rounded-xl border border-ink-300 bg-white p-7 transition hover:border-sindzo-300 hover:shadow-sm">
        <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-greensoft text-sindzo-700">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" set:html={u.iconPath} />
        </div>
        <h3 class="mt-4 font-display text-xl font-semibold text-ink-900">{u.title}</h3>
        <p class="mt-2 text-ink-700 leading-relaxed">{u.body}</p>
        <a href={u.link.href} class="mt-5 inline-block text-sm font-medium text-sindzo-700 no-underline hover:underline">
          {u.link.label} →
        </a>
      </article>
    ))}
  </div>
</section>
