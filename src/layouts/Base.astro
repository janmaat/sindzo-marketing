---
import Nav from '../components/Nav.astro';
import EarlyAccessBanner from '../components/EarlyAccessBanner.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
}

const {
  title,
  description = 'Coheza — één zorgsuite voor dossier, planning, declaratie en kwaliteit. Bewust open, aantoonbaar veilig, gebouwd voor de Nederlandse zorgpraktijk.',
  canonical,
  image = '/og.png',
} = Astro.props;

const url = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Coheza',
  alternateName: 'Coheza Naast',
  url: Astro.site?.toString() ?? 'https://coheza.nl',
  logo: new URL('/logo/coheza-logo.svg', Astro.site).toString(),
  description: 'Eén modulair zorgplatform voor de Nederlandse VVT, gehandicaptenzorg en GGZ — dossier, planning, declaratie, kwaliteit, meertalig cliëntportaal (7 talen) en welzijn-modules voor medewerkers.',
  foundingLocation: { '@type': 'Place', address: { '@type': 'PostalAddress', addressLocality: 'Almelo', addressCountry: 'NL' }},
  areaServed: { '@type': 'Country', name: 'Nederland' },
  knowsAbout: [
    'Elektronisch Cliëntdossier (ECD)',
    'FHIR R4',
    'NEN 7510',
    'NIS2 / Cyberbeveiligingswet',
    'Meertalig cliëntportaal',
    'Wegiz eOverdracht',
    'MedMij',
    'iWmo iJw iWlz',
    'ZPM-declaratie GGZ',
    'Peer-support voor zorgmedewerkers',
    'AVG / DPIA',
  ],
  knowsLanguage: ['nl', 'en', 'tr', 'ar', 'de', 'pl', 'uk'],
  email: 'hello@coheza.nl',
  telephone: '+31611746283',
  contactPoint: [
    {
      '@type': 'ContactPoint',
      contactType: 'sales',
      telephone: '+31611746283',
      email: 'hello@coheza.nl',
      areaServed: 'NL',
      availableLanguage: ['Dutch', 'English'],
    },
    {
      '@type': 'ContactPoint',
      contactType: 'security',
      email: 'trust@coheza.nl',
      areaServed: 'NL',
      availableLanguage: ['Dutch', 'English'],
    },
  ],
};
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:locale" content="nl_NL" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#0E4F57" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(orgLd)} />
    {/* Fonts (Fraunces + Mulish) worden self-hosted geladen via src/styles/fonts.css. */}
    {/*
      Plausible Analytics — cookie-loos, EU-gehost (geen GA, geen tracker-popups).
      Alleen in productie laden zodat dev-traffic geen statistiek vervuilt.
    */}
    {import.meta.env.PROD && (
      <script defer data-domain="coheza.nl" src="https://plausible.io/js/script.outbound-links.js"></script>
      <script is:inline set:html={`window.plausible = window.plausible || function() { (window.plausible.q = window.plausible.q || []).push(arguments) }`} />
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    {/* Skip-link voor keyboard-users — verbergt visueel, verschijnt op focus. */}
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:rounded focus:bg-sindzo-900 focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white focus:no-underline focus:outline focus:outline-2 focus:outline-accent-500"
    >
      Direct naar inhoud
    </a>
    <EarlyAccessBanner />
    <Nav />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
