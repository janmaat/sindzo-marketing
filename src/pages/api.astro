---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Cta from '../components/Cta.astro';

// Tijdelijke /api landingspagina tot api.coheza.nl/docs publiek live is.
// Vervangt diverse externe links die nu nog 404 geven. Geef hier eerlijk weer
// wat productie-ready is, wat in afronding zit, en hoe iemand vandaag al de
// spec / sandbox-toegang krijgt.

const resources = [
  { name: 'Patient', desc: 'Cliëntdemografie, BSN, contactgegevens — Zib-profiel.', status: 'live' },
  { name: 'Encounter', desc: 'Zorgmoment/contact — episode of care-context.', status: 'live' },
  { name: 'Observation', desc: 'Metingen, scores, vitale waarden.', status: 'live' },
  { name: 'MedicationStatement', desc: 'Actuele medicatie-overzicht (Zib MedicationOverview).', status: 'live' },
  { name: 'Condition', desc: 'Probleem-/diagnoseregistratie.', status: 'live' },
  { name: 'AllergyIntolerance', desc: 'Allergieën en intoleranties.', status: 'live' },
  { name: 'RelatedPerson', desc: 'Mantelzorger, wettelijk vertegenwoordiger, contactpersonen.', status: 'live' },
  { name: 'CarePlan', desc: 'Zorgplan-export — Omaha gemapped.', status: 'wip' },
  { name: 'Practitioner / PractitionerRole', desc: 'Zorgverlener + AGB-koppeling.', status: 'wip' },
];

const dot = (s: string) =>
  s === 'live' ? 'bg-green-500' : s === 'wip' ? 'bg-amber-500' : 'bg-ink-300';
---
<Base
  title="API & FHIR-endpoints — Coheza"
  description="Coheza API op basis van FHIR R4 met Nederlandse Zib-profielen. OAuth2, OpenAPI 3.1-spec en sandbox-toegang op aanvraag — publieke sandbox in afronding."
>
  <PageHero
    eyebrow="API & integratie"
    title="FHIR R4 met Zib-profielen."
    subtitle="Coheza levert een open, gedocumenteerde API rondom de Nederlandse Zib-standaarden. Endpoints draaien in productie; publieke sandbox en interactieve docs zijn in afronding. Tot dan: spec en sandbox-toegang op aanvraag binnen 1 werkdag."
  >
    <div slot="actions" class="flex flex-wrap gap-3">
      <a href="mailto:api@coheza.nl?subject=OpenAPI%20spec%20%2B%20sandbox-toegang" class="btn-primary no-underline">Spec + sandbox aanvragen</a>
      <a href="/integraties" class="btn-secondary no-underline">Overzicht integraties</a>
    </div>
  </PageHero>

  <section class="container-prose py-12 border-b border-ink-100 bg-ink-100/40">
    <div class="rounded-xl border border-amber-200 bg-amber-50/60 p-5 max-w-3xl">
      <div class="text-[10px] font-extrabold uppercase tracking-[0.22em] text-amber-900">Publieke sandbox in afronding</div>
      <p class="mt-2 text-sm text-ink-700 leading-relaxed">
        api.coheza.nl/docs (Swagger UI) en de publieke sandbox-tenant gaan live in Q3 2026.
        Tot dan: stuur een mail naar <a href="mailto:api@coheza.nl" class="text-sindzo-700 hover:underline">api@coheza.nl</a> —
        u krijgt de OpenAPI 3.1-spec, een test-client_id/secret en een gesegregeerde sandbox-tenant met
        synthetische cliëntdata. Reactie binnen 1 werkdag, geen NDA nodig.
      </p>
    </div>
  </section>

  <section class="container-prose py-14 border-b border-ink-100">
    <h2 class="font-display text-2xl font-bold text-ink-900">FHIR R4 resources</h2>
    <p class="mt-2 text-sm text-ink-700 max-w-2xl">
      Resources mappen naar Nederlandse Zorginformatiebouwstenen (Zib's) waar deze gedefinieerd zijn.
      Status reflecteert publieke endpoint-beschikbaarheid; interne implementatie kan verder zijn.
    </p>
    <ul class="mt-6 grid gap-3 sm:grid-cols-2">
      {resources.map((r) => (
        <li class="flex items-start gap-3 rounded-lg border border-ink-100 bg-white p-4">
          <span class={`status-dot mt-1.5 shrink-0 ${dot(r.status)}`}></span>
          <div>
            <div class="text-sm font-semibold text-ink-900">{r.name}</div>
            <div class="mt-0.5 text-xs text-ink-500">{r.desc}</div>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <section class="container-prose py-14 border-b border-ink-100">
    <h2 class="font-display text-2xl font-bold text-ink-900">Authenticatie & autorisatie</h2>
    <ul class="mt-4 space-y-2 text-sm text-ink-700">
      <li>• <strong class="text-ink-900">OAuth2 client-credentials</strong> voor server-to-server (back-office, ketenpartners).</li>
      <li>• <strong class="text-ink-900">OAuth2 authorization-code + PKCE</strong> voor cliënt-gerichte apps via cliëntportaal-flow.</li>
      <li>• <strong class="text-ink-900">SMART-on-FHIR scopes</strong> (`patient/*.read`, `user/*.read`) voor fijnmazige toegang per resource.</li>
      <li>• <strong class="text-ink-900">UZI-mTLS</strong> beschikbaar voor zorgverlener-authenticatie (in afronding, CIBG-cert vereist).</li>
    </ul>
  </section>

  <section class="container-prose py-14 border-b border-ink-100">
    <h2 class="font-display text-2xl font-bold text-ink-900">Wat we niet doen</h2>
    <p class="mt-2 text-sm text-ink-700 max-w-3xl leading-relaxed">
      Geen proprietary "Coheza-formaat" parallel aan FHIR. Geen lock-in via custom payloads.
      Geen rate-limit-tarieven voor klanten of geverifieerde ketenpartners. Geen verschil tussen wat in
      onze UI beschikbaar is en wat via de API kan — op een paar admin-endpoints na die expliciet
      gedocumenteerd zijn.
    </p>
  </section>

  <Cta
    title="Implementatiepartner of ketenleverancier?"
    subtitle="Wij helpen integratiepartners graag op weg met spec, sandbox en architectuurklankbord. Mail rechtstreeks naar api@coheza.nl."
  />
</Base>
