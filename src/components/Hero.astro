---
// Hero-claim is bewust niet feature-led: het rapport leerde dat in dit segment
// vertrouwen en procesfit zwaarder wegen dan functielijsten.
---
<section class="relative isolate overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-gradient-to-br from-sindzo-50 via-cream to-cream"></div>
  {/* One-pager-stijl radial gloed in rechterbovenhoek (accent + petrol). */}
  <div
    class="absolute -top-48 -right-40 -z-10 h-[640px] w-[640px] rounded-full opacity-80"
    style="background: radial-gradient(circle at 30% 30%, rgba(63,163,122,0.16), rgba(14,66,61,0.06) 55%, transparent 72%);"
  ></div>
  {/* Subtiele zandkleurige onderkant-wash voor warmte. */}
  <div class="absolute -bottom-32 -left-32 -z-10 h-[420px] w-[420px] rounded-full bg-sand/70 opacity-70 blur-3xl"></div>
  <div class="container-prose pt-20 pb-24 sm:pt-28 sm:pb-32">
    <div class="max-w-3xl">
      <span class="badge mb-6">
        <span class="status-dot bg-accent-500"></span>
        Built in the Netherlands · NEN 7510 in voorbereiding
      </span>
      <h1 class="font-display text-4xl font-bold leading-tight tracking-tightish text-ink-900 sm:text-5xl md:text-6xl">
        Minder regeldruk. <span class="italic text-accent-600">Meer tijd voor zorg.</span>
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-ink-700 max-w-2xl">
        Coheza bundelt ECD, planning, declaratie en kwaliteit in één modulair platform —
        bewust open (FHIR R4-architectuur gereed, MedMij en Wegiz in afronding) en aantoonbaar veilig.
        Eén werkruimte, één leverancier, één keer registreren — gebouwd voor de Nederlandse
        VVT, gehandicaptenzorg en GGZ.
      </p>
      <div class="mt-9 flex flex-wrap items-center gap-3">
        <a href="/demo" class="btn-primary no-underline">Demo aanvragen</a>
        <a href="/oplossing" class="btn-secondary no-underline">Bekijk de oplossing</a>
        <a href="/trust" class="ml-2 text-sm font-medium text-sindzo-700 no-underline hover:underline">
          Of begin bij Trust Centre →
        </a>
      </div>
      <p class="mt-8 text-sm text-ink-500">
        Reactie binnen 1 werkdag · Demo op uw eigen zorgproces · Geen verkoopdruk
      </p>
    </div>
  </div>
</section>
