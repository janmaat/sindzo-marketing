---
// Hero-claim is bewust niet feature-led: het rapport leerde dat in dit segment
// vertrouwen en procesfit zwaarder wegen dan functielijsten.
---
<section class="relative isolate overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-gradient-to-br from-sindzo-50 via-white to-white"></div>
  <div class="absolute -top-40 -right-40 -z-10 h-[480px] w-[480px] rounded-full bg-sindzo-100 opacity-60 blur-3xl"></div>
  <div class="container-prose pt-20 pb-24 sm:pt-28 sm:pb-32">
    <div class="max-w-3xl">
      <span class="badge mb-6">
        <span class="status-dot bg-green-500"></span>
        Built in the Netherlands · NEN 7510 in voorbereiding
      </span>
      <h1 class="font-display text-4xl font-bold leading-tight tracking-tightish text-ink-900 sm:text-5xl md:text-6xl">
        Eén zorgsuite voor <span class="text-sindzo-700">dossier, planning, declaratie en kwaliteit</span>.
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-ink-700 max-w-2xl">
        Sindzo bundelt ECD, declaratie, planning en kwaliteit in één modulair platform — bewust open
        (FHIR, MedMij, Wegiz), aantoonbaar veilig en gebouwd voor de Nederlandse VVT, gehandicaptenzorg
        en GGZ. Minder regeldruk, snellere adoptie, één leverancier.
      </p>
      <div class="mt-9 flex flex-wrap items-center gap-3">
        <a href="/demo" class="btn-primary no-underline">Demo aanvragen</a>
        <a href="/oplossing" class="btn-secondary no-underline">Bekijk de oplossing</a>
        <a href="/trust" class="ml-2 text-sm font-medium text-sindzo-700 no-underline hover:underline">
          Of begin bij Trust Centre →
        </a>
      </div>
      <p class="mt-8 text-sm text-ink-500">
        Reactie binnen 1 werkdag · Demo op uw eigen zorgproces · Geen verkoopdruk
      </p>
    </div>
  </div>
</section>
