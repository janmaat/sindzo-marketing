---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Cta from '../components/Cta.astro';

// Procurement-pagina — bewust geen lead-gate vóór de downloads.
// In de Nederlandse zorg verlengt elke gate de cyclus met dagen omdat
// inkoop, FG en architectuur ieder hun eigen review willen doen.
// Geef materiaal weg en bouw vertrouwen, in plaats van leads te scrapen.

interface Resource {
  title: string;
  body: string;
  /** Pad naar publiek bestand óf 'mailto:...' voor on-demand levering. */
  file: string;
  /** Toon-label naast titel (bv. 'PDF · 220 kB' of 'Op aanvraag · ~1 werkdag'). */
  format: string;
  category: string;
}

// Tijdens early-access leveren we elk procurement-document op-maat per aanvraag —
// PVE, DPA, DPIA, SLA, CAIQ etc. worden gegenereerd zodra een specifieke organisatie
// (en haar segment + schaal) bekend is. Voorkomt dat we generieke versies de wereld
// in slingeren die later moeten worden teruggeroepen. Alleen de API-pagina is een
// directe link (interne pagina, geen download).
const onRequest = (subject: string) =>
  `mailto:procurement@sindzo.nl?subject=${encodeURIComponent('Aanvraag procurement-document: ' + subject)}`;

const resources: Resource[] = [
  {
    category: 'PVE & shortlisting',
    title: 'PVE-template zorgsuite',
    body: 'Word-document met 180+ eisen-categorieën die u kunt aanvinken/aanpassen. Bedoeld voor een zorgvuldige shortlisting, niet als invul-spreadsheet.',
    file: onRequest('PVE-template zorgsuite'),
    format: 'Op aanvraag · ~1 werkdag',
  },
  {
    category: 'PVE & shortlisting',
    title: 'Vergelijkingsmatrix leveranciers',
    body: 'Excel met scoring-criteria per dimensie (functioneel, technisch, commercieel) — leverancier-onafhankelijk opgesteld.',
    file: onRequest('Vergelijkingsmatrix leveranciers'),
    format: 'Op aanvraag · ~1 werkdag',
  },
  {
    category: 'Privacy & security',
    title: 'Verwerkersovereenkomst (DPA)',
    body: 'Onze standaard-DPA. AP-conform model met expliciete sub-verwerkers-bijlage. Geen NDA nodig om in te zien.',
    file: onRequest('DPA Sindzo'),
    format: 'Op aanvraag · binnen 1 werkdag',
  },
  {
    category: 'Privacy & security',
    title: 'DPIA-template (uw eigen)',
    body: 'Template voor uw eigen DPIA bij Sindzo-aanschaf. Met voorbeeld-risicoanalyse en mitigerende maatregelen.',
    file: onRequest('DPIA-template zorgaanbieder'),
    format: 'Op aanvraag · ~1 werkdag',
  },
  {
    category: 'Privacy & security',
    title: 'Security-pack',
    body: 'NEN 7510-statement, controls-evidence-bundle, pentest-samenvatting, sub-verwerker-lijst.',
    file: onRequest('Security-pack'),
    format: 'Op aanvraag · binnen 1 werkdag',
  },
  {
    category: 'Privacy & security',
    title: 'Vragenlijst CAIQ / SIG',
    body: 'Ingevulde CAIQ v4.0.3 en kort SIG-formulier. Voor procurement/CISO-teams die niet opnieuw willen vragen.',
    file: onRequest('CAIQ / SIG-vragenlijst'),
    format: 'Op aanvraag · ~2 werkdagen',
  },
  {
    category: 'Architectuur & SLA',
    title: 'Architectuurplaat',
    body: 'Eén-pager met modulaire monolith, integraties, hosting, identity, datatypes, data-flow. Voor I&A/architectuur.',
    file: onRequest('Architectuurplaat'),
    format: 'Op aanvraag · ~1 werkdag',
  },
  {
    category: 'Architectuur & SLA',
    title: 'SLA-overzicht',
    body: 'Service Level Agreement met uptime, RPO/RTO, support-windows, financiële boete-clausule voor Enterprise.',
    file: onRequest('SLA-overzicht'),
    format: 'Op aanvraag · binnen 1 werkdag',
  },
  {
    category: 'Architectuur & SLA',
    title: 'API-koppeldocumentatie',
    body: 'FHIR R4-endpoints en OpenAPI 3.1-spec. Publieke pagina met overzicht; volledige spec + sandbox-toegang op aanvraag.',
    file: '/api',
    format: 'Web · direct',
  },
  {
    category: 'Implementatie',
    title: 'Implementatie-aanpak (deck)',
    body: '20-pagina presentatie voor projectgroep en bestuur: fasen, governance, super-users, time-to-value.',
    file: onRequest('Implementatie-deck'),
    format: 'Op aanvraag · ~1 werkdag',
  },
  {
    category: 'Implementatie',
    title: 'Migratie-handleiding ECD/HIS',
    body: 'Per herkomst-systeem wat wij importeren, wat handwerk is, hoe lang. Productie-imports beschikbaar voor Nedap Ons; Gerimedica Ysis in voorbereiding; SDB en Adapcare als maatwerk-import.',
    file: onRequest('Migratie-handleiding ECD/HIS'),
    format: 'Op aanvraag · ~2 werkdagen',
  },
  {
    category: 'Business case',
    title: 'ROI-rekenhulp',
    body: 'Spreadsheet om uw eigen TCO/ROI in te vullen. Met realistische ranges per segment en plan-tier.',
    file: onRequest('ROI-rekenhulp'),
    format: 'Op aanvraag · ~1 werkdag',
  },
];

const categories = Array.from(new Set(resources.map(r => r.category)));
---
<Base
  title="Procurement Centre — beslis-versnellers | Sindzo"
  description="PVE-template, DPA, security-pack, architectuurplaat, SLA, ROI-rekenhulp — alles wat uw inkoop-, FG- en I&A-team nodig heeft. Geen lead-gate."
>
  <PageHero
    eyebrow="Procurement Centre"
    title="Beslis-versnellers, voor uw hele team."
    subtitle="In de zorgsector heeft een aankoop minimaal vier interne lezers: bestuur, inkoop, FG, I&A. Hieronder downloadt u alles wat zij nodig hebben — zonder lead-gate, zonder NDA, zonder ons om toestemming te vragen."
  >
    <div slot="actions" class="flex flex-wrap gap-3">
      <a href="/demo" class="btn-primary no-underline">Of: vraag een demo aan</a>
      <a href="/trust" class="btn-secondary no-underline">Of: ga naar Trust Centre</a>
    </div>
  </PageHero>

  <section class="border-y border-amber-200 bg-amber-50 py-6">
    <div class="container-prose">
      <p class="text-sm text-amber-900">
        <strong>Early-access: documenten op-maat per aanvraag.</strong>
        We genereren elk document afgestemd op uw segment, schaal en specifieke vraagstukken — in plaats van generieke
        versies die later moeten worden teruggeroepen. Reactie binnen 1 werkdag. Voor uw definitieve PVE of DPA: laat
        uw eigen jurist/FG meekijken — onze documenten zijn werkdocumenten, geen juridisch advies.
      </p>
    </div>
  </section>

  {categories.map((cat) => (
    <section class="container-prose py-14 border-b border-ink-100 last:border-0">
      <h2 class="font-display text-2xl font-bold text-ink-900">{cat}</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {resources.filter(r => r.category === cat).map((r) => (
          <article class="rounded-xl border border-ink-100 bg-white p-6">
            <div class="flex items-start justify-between gap-4">
              <h3 class="font-display text-lg font-semibold text-ink-900">{r.title}</h3>
              <span class="badge whitespace-nowrap">{r.format}</span>
            </div>
            <p class="mt-2 text-sm text-ink-700 leading-relaxed">{r.body}</p>
            {r.file.startsWith('mailto:') ? (
              <a href={r.file} class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-sindzo-700 no-underline hover:underline">
                <span>✉ Aanvragen via e-mail</span>
              </a>
            ) : (
              <a href={r.file} class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-sindzo-700 no-underline hover:underline">
                <span>→ Bekijken</span>
              </a>
            )}
          </article>
        ))}
      </div>
    </section>
  ))}

  <section class="container-prose py-16">
    <div class="rounded-2xl border border-ink-200 bg-ink-100/50 p-8">
      <h2 class="font-display text-2xl font-bold text-ink-900">Mist u iets?</h2>
      <p class="mt-3 max-w-2xl text-ink-700">
        Geen invul-spreadsheet die uw inkoop wil, geen specifiek security-document dat uw CISO opvraagt?
        Mail het ons — wij voegen het toe of leveren maatwerk binnen 1 werkdag.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="mailto:procurement@sindzo.nl" class="btn-primary no-underline">procurement@sindzo.nl</a>
        <a href="mailto:trust@sindzo.nl" class="btn-secondary no-underline">trust@sindzo.nl (voor security)</a>
      </div>
    </div>
  </section>

  <Cta
    title="Klaar voor de demo nadat u dit allemaal heeft gelezen?"
    subtitle="Stuur drie typische werkstromen uit uw organisatie. Wij komen niet met een sales-pitch maar met uw eigen processen op het scherm."
  />
</Base>
