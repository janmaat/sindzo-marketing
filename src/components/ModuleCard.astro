---
interface Props {
  icon: string;
  title: string;
  body: string;
  features?: string[];
  status?: 'live' | 'wip' | 'roadmap';
  href?: string;
}
const { icon, title, body, features = [], status = 'live', href } = Astro.props;

const statusColor =
  status === 'live' ? 'bg-green-500' : status === 'wip' ? 'bg-amber-500' : 'bg-ink-300';
const statusLabel =
  status === 'live' ? 'Beschikbaar' : status === 'wip' ? 'In ontwikkeling' : 'Op roadmap';
---
<article class="flex flex-col rounded-xl border border-ink-100 bg-white p-6 transition hover:border-sindzo-200 hover:shadow-sm">
  <div class="flex items-start justify-between gap-3">
    <div class="text-2xl text-sindzo-700">{icon}</div>
    <span class="flex items-center gap-1.5 text-[10px] uppercase tracking-wider text-ink-500">
      <span class={`status-dot ${statusColor}`}></span>{statusLabel}
    </span>
  </div>
  <h3 class="mt-4 font-display text-lg font-semibold text-ink-900">{title}</h3>
  <p class="mt-2 flex-1 text-sm text-ink-700 leading-relaxed">{body}</p>
  {features.length > 0 && (
    <ul class="mt-4 space-y-1.5 text-xs text-ink-700">
      {features.map((f) => (
        <li class="flex items-start gap-2">
          <span class="mt-1 inline-block h-1 w-1 rounded-full bg-sindzo-500"></span>
          <span>{f}</span>
        </li>
      ))}
    </ul>
  )}
  {href && (
    <a href={href} class="mt-5 text-sm font-medium text-sindzo-700 no-underline hover:underline">
      Meer over {title.toLowerCase()} →
    </a>
  )}
</article>
