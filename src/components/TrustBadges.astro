---
// Status-stoplichten zijn bewust eerlijk: groen = aantoonbaar, geel = in
// voorbereiding, grijs = roadmap. Dit is het centrale differentiërende element
// t.o.v. concurrenten die compliance pas in tender-fase delen.
const badges = [
  { label: 'NEN 7510', status: 'wip', note: 'Werkdocument, certificering Q4 2026' },
  { label: 'AVG / GDPR', status: 'live', note: 'DPA & sub-verwerkerslijst publiek' },
  { label: 'ISO 27001', status: 'roadmap', note: 'Audit gepland 2027' },
  { label: 'FHIR R4', status: 'live', note: 'Endpoints publiek gedocumenteerd' },
  { label: 'MedMij', status: 'wip', note: 'Aansluiting in afrondingsfase' },
  { label: 'Wegiz', status: 'wip', note: 'eOverdracht-bundle live' },
  { label: 'Cbw-ready', status: 'wip', note: 'Voorbereidingen 1 juli 2026' },
  { label: 'NL-hosting', status: 'live', note: 'Azure West-Europe + backup NL' },
];

const dot = (s: string) =>
  s === 'live' ? 'bg-green-500' : s === 'wip' ? 'bg-amber-500' : 'bg-ink-300';
---
<section class="border-y border-ink-100 bg-ink-100/40 py-14">
  <div class="container-prose">
    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 class="font-display text-2xl font-bold text-ink-900">Compliance op tafel — niet in een PDF achter een NDA.</h2>
        <p class="mt-2 text-sm text-ink-700 max-w-2xl">
          Eerlijke status per kader. Klik door naar het Trust Centre voor onderbouwing per item.
        </p>
      </div>
      <a href="/trust" class="text-sm font-medium text-sindzo-700 no-underline hover:underline whitespace-nowrap">
        Volledig Trust Centre →
      </a>
    </div>
    <ul class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
      {badges.map((b) => (
        <li class="flex items-start gap-3 rounded-lg border border-ink-100 bg-white p-4">
          <span class={`status-dot mt-1.5 ${dot(b.status)}`}></span>
          <div>
            <div class="text-sm font-semibold text-ink-900">{b.label}</div>
            <div class="mt-0.5 text-xs text-ink-500">{b.note}</div>
          </div>
        </li>
      ))}
    </ul>
    <p class="mt-6 text-xs text-ink-500">
      <span class="status-dot bg-green-500"></span> aantoonbaar nu  ·
      <span class="status-dot bg-amber-500 ml-2"></span> in afronding  ·
      <span class="status-dot bg-ink-300 ml-2"></span> op roadmap
    </p>
  </div>
</section>
