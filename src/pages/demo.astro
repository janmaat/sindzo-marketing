---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import HoneypotField from '../components/HoneypotField.astro';

// Form-action wijst naar de app-side endpoint zodat leads direct in de CRM
// landen — geen Hubspot of separate lead-store nodig. Implementeer
// AllowAnonymous-endpoint /api/lead in Sindzo.Host.
const formAction = 'https://app.sindzo.nl/api/lead';
---
<Base
  title="Demo aanvragen — Sindzo"
  description="Demo op uw eigen zorgproces. Reactie binnen 1 werkdag. Geen verkoopdruk."
>
  <PageHero
    eyebrow="Demo aanvragen"
    title="Demo op uw eigen werkprocessen."
    subtitle="Stuur drie typische werkstromen uit uw organisatie. Wij laten zien hoe Sindzo ze ondersteunt — geen scripted sales-pitch."
  />

  <section class="container-prose py-16">
    {/*
      Mail-fallback bovenaan: het formulier post naar app.sindzo.nl/api/lead,
      maar tijdens early-access kan die backend nog niet volledig stabiel zijn.
      De mailto-knop is geen vervanging maar een laagdrempelig alternatief.
    */}
    <div class="mb-10 max-w-3xl rounded-xl border border-ink-100 bg-greensoft/40 p-5">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <p class="text-sm text-ink-700">
          <strong class="text-ink-900">Liever direct mailen?</strong>
          Geen formulier nodig — stuur een korte mail met uw werkstromen.
        </p>
        <a
          href="mailto:hello@sindzo.nl?subject=Demo%20aanvraag&body=Hallo%2C%0A%0AIk%20wil%20een%20demo%20aanvragen.%20Drie%20typische%20werkstromen%3A%0A1.%20%0A2.%20%0A3.%20%0A%0AOrganisatie%3A%20%0ARol%3A%20%0ASegment%3A%20"
          class="btn-secondary no-underline"
        >
          ✉ hello@sindzo.nl
        </a>
      </div>
    </div>
    <div class="grid gap-12 lg:grid-cols-[1fr_320px]">
      <form action={formAction} method="post" class="rounded-2xl border border-ink-100 bg-white p-8">
        <input type="hidden" name="source" value="marketing/demo" />
        <input type="hidden" name="product" value="sindzo" />
        <HoneypotField />

        <div class="grid gap-5 sm:grid-cols-2">
          <label class="block">
            <span class="text-sm font-semibold text-ink-900">Voornaam</span>
            <input required type="text" name="firstName" autocomplete="given-name"
                   class="mt-1.5 block w-full rounded-md border-ink-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-sindzo-500 focus:ring-sindzo-500" />
          </label>
          <label class="block">
            <span class="text-sm font-semibold text-ink-900">Achternaam</span>
            <input required type="text" name="lastName" autocomplete="family-name"
                   class="mt-1.5 block w-full rounded-md border-ink-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-sindzo-500 focus:ring-sindzo-500" />
          </label>
          <label class="block">
            <span class="text-sm font-semibold text-ink-900">Zakelijk e-mailadres</span>
            <input required type="email" name="email" autocomplete="email"
                   class="mt-1.5 block w-full rounded-md border-ink-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-sindzo-500 focus:ring-sindzo-500" />
          </label>
          <label class="block">
            <span class="text-sm font-semibold text-ink-900">Telefoon (optioneel)</span>
            <input type="tel" name="phone" autocomplete="tel"
                   class="mt-1.5 block w-full rounded-md border-ink-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-sindzo-500 focus:ring-sindzo-500" />
          </label>
          <label class="block sm:col-span-2">
            <span class="text-sm font-semibold text-ink-900">Organisatie</span>
            <input required type="text" name="organization"
                   class="mt-1.5 block w-full rounded-md border-ink-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-sindzo-500 focus:ring-sindzo-500" />
          </label>
          <label class="block">
            <span class="text-sm font-semibold text-ink-900">Rol</span>
            <select name="role" class="mt-1.5 block w-full rounded-md border-ink-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-sindzo-500 focus:ring-sindzo-500">
              <option value="">Kies een rol</option>
              <option>Bestuurder / RvB</option>
              <option>Manager I&amp;A / CIO</option>
              <option>CMIO / CNIO / zorginhoudelijk leider</option>
              <option>Functioneel beheer</option>
              <option>FG / CISO / privacy</option>
              <option>Finance / control</option>
              <option>Anders</option>
            </select>
          </label>
          <label class="block">
            <span class="text-sm font-semibold text-ink-900">Segment</span>
            <select name="segment" class="mt-1.5 block w-full rounded-md border-ink-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-sindzo-500 focus:ring-sindzo-500">
              <option value="">Kies een segment</option>
              <option>VVT</option>
              <option>Gehandicaptenzorg</option>
              <option>GGZ</option>
              <option>Huisartsenzorg</option>
              <option>Jeugdzorg</option>
              <option>Kraamzorg</option>
              <option>Anders</option>
            </select>
          </label>
        </div>

        <label class="mt-5 block">
          <span class="text-sm font-semibold text-ink-900">Drie typische werkstromen die u wilt zien</span>
          <textarea name="workflows" rows="4"
                    placeholder="Bijv. 'opstellen zorgplan na intake', 'eOverdracht naar ziekenhuis', 'maandelijkse iWmo-declaratie'"
                    class="mt-1.5 block w-full rounded-md border-ink-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-sindzo-500 focus:ring-sindzo-500"></textarea>
        </label>

        <label class="mt-5 flex items-start gap-3 text-sm text-ink-700">
          <input required type="checkbox" name="consent" value="yes"
                 class="mt-0.5 h-4 w-4 rounded border-ink-300 text-sindzo-600 focus:ring-sindzo-500" />
          <span>
            Ik ga akkoord met de verwerking van mijn gegevens conform de
            <a href="/privacy" class="text-sindzo-700 hover:underline">privacyverklaring</a>.
            Geen marketinglijst, geen doorverkoop.
          </span>
        </label>

        <button type="submit" class="btn-primary mt-7">
          Demo aanvragen
        </button>
        <p class="mt-4 text-xs text-ink-500">
          Reactie binnen 1 werkdag — meestal sneller. Vragen vooraf? Bel
          <a href="tel:+31611746283" class="text-sindzo-700 hover:underline">+31 6 11 74 62 83</a>.
        </p>
      </form>

      <aside class="space-y-6">
        <div class="rounded-2xl border border-ink-100 bg-ink-100/50 p-6">
          <h3 class="font-display text-lg font-semibold text-ink-900">Wat te verwachten</h3>
          <ol class="mt-4 space-y-3 text-sm text-ink-700">
            <li class="flex gap-3">
              <span class="font-semibold text-sindzo-700">1.</span>
              <span>Korte verkenning (30 min) — uw situatie, doelen, ICT-landschap.</span>
            </li>
            <li class="flex gap-3">
              <span class="font-semibold text-sindzo-700">2.</span>
              <span>Demo op úw werkstromen (60 min) — uw rollen, uw begrippen, uw flows.</span>
            </li>
            <li class="flex gap-3">
              <span class="font-semibold text-sindzo-700">3.</span>
              <span>Beslis-pakket: security-pack, DPA, indicatie-prijs, voorstel-implementatie.</span>
            </li>
          </ol>
        </div>
        <div class="rounded-2xl border border-ink-100 bg-white p-6">
          <h3 class="font-display text-lg font-semibold text-ink-900">Liever eerst zelf rondkijken?</h3>
          <ul class="mt-3 space-y-2 text-sm">
            <li><a href="/oplossing" class="text-sindzo-700 hover:underline no-underline">→ Bekijk de modulekaart</a></li>
            <li><a href="/trust" class="text-sindzo-700 hover:underline no-underline">→ Open Trust Centre</a></li>
            <li><a href="/integraties" class="text-sindzo-700 hover:underline no-underline">→ Bekijk koppelingen</a></li>
            <li><a href="/prijzen" class="text-sindzo-700 hover:underline no-underline">→ Plan-matrix</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </section>
</Base>
