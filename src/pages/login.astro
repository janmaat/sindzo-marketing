---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';

// Hub-pagina voor drie portalen. Vermijdt verwarring: één Inloggen-knop in
// de Nav, gebruiker kiest hier welk portaal hij/zij nodig heeft. Bij directe
// kennis van het portaal kan iemand ook rechtstreeks naar bv. medewerker.sindzo.nl.

const portals = [
  {
    audience: 'Zorgmedewerkers',
    title: 'Medewerker-portaal',
    body: 'Voor zorgverleners en backoffice: dossier, planning, declaratie, kwaliteit. UZI-authenticatie waar wettelijk vereist.',
    href: 'https://medewerker.sindzo.nl/',
    cta: 'Open medewerker.sindzo.nl',
    icon: '👩‍⚕️',
  },
  {
    audience: 'Cliënten & mantelzorgers',
    title: 'Cliëntportaal',
    body: 'Voor cliënten, mantelzorgers en familie: berichten, documenten, machtigingen, mantelzorger-taken en eigen zorgplan inzien.',
    href: 'https://klant.sindzo.nl/',
    cta: 'Open klant.sindzo.nl',
    icon: '🏠',
  },
  {
    audience: 'Beheer & I&A',
    title: 'Beheer-omgeving',
    body: 'Voor I&A-beheerders en functioneel beheer: tenant-configuratie, gebruikers- en rollen-beheer, integratie-instellingen, audit-export.',
    href: 'https://app.sindzo.nl/login',
    cta: 'Open app.sindzo.nl',
    icon: '⚙',
  },
];
---
<Base
  title="Inloggen — kies uw portaal | Sindzo"
  description="Drie Sindzo-portalen: medewerker.sindzo.nl voor zorgverleners, klant.sindzo.nl voor cliënten en mantelzorgers, app.sindzo.nl voor beheer."
>
  <PageHero
    eyebrow="Inloggen"
    title="Welk portaal heeft u nodig?"
    subtitle="Sindzo heeft drie aparte portalen voor verschillende gebruikers. Kies hieronder, of ga rechtstreeks naar de URL als u die kent."
  />

  <section class="container-prose py-12">
    <div class="grid gap-5 md:grid-cols-3">
      {portals.map((p) => (
        <a
          href={p.href}
          class="group rounded-2xl border border-ink-200 bg-white p-6 no-underline transition hover:border-sindzo-300 hover:shadow-md"
        >
          <div class="text-3xl" aria-hidden="true">{p.icon}</div>
          <div class="mt-4 text-xs font-semibold uppercase tracking-wider text-accent-700">{p.audience}</div>
          <h2 class="mt-1 font-display text-xl font-semibold text-ink-900">{p.title}</h2>
          <p class="mt-2 text-sm text-ink-700 leading-relaxed">{p.body}</p>
          <span class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-sindzo-700 transition group-hover:translate-x-0.5">
            {p.cta} →
          </span>
        </a>
      ))}
    </div>

    <div class="mt-12 rounded-xl border border-ink-100 bg-ink-100/40 p-6 max-w-3xl">
      <h2 class="font-display text-base font-semibold text-ink-900">Weet u niet welk portaal?</h2>
      <p class="mt-2 text-sm text-ink-700">
        Werkt u <strong>bij</strong> een zorgaanbieder die Sindzo gebruikt? Vraag uw beheerder
        om uitnodiging — dan landt u in het juiste portaal. Bent u <strong>cliënt of mantelzorger</strong>?
        De uitnodiging komt vanuit de zorgaanbieder, niet vanuit Sindzo direct.
      </p>
      <p class="mt-3 text-sm text-ink-500">
        Vragen? Mail <a href="mailto:support@sindzo.nl" class="text-sindzo-700 hover:underline">support@sindzo.nl</a>
        of bel <a href="tel:+31611746283" class="text-sindzo-700 hover:underline">+31 6 11 74 62 83</a>.
      </p>
    </div>
  </section>
</Base>
