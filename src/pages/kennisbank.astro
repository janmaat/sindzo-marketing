---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Cta from '../components/Cta.astro';

// Kennisbank-stub: voorkomt 404 vanuit footer-link en zaait inhoud voor
// geplande SEO-artikelen rond zorgregelgeving en interoperabiliteit.
// Vervang door echte artikel-listing zodra de eerste artikelen gepubliceerd zijn.

const plannedArticles = [
  {
    category: 'Regelgeving',
    title: 'Wtza-jaarverantwoording: het stappenplan voor 31 mei',
    body: 'Wat moet u aanleveren via DigiMV, welke modules helpen, waar zitten de valkuilen.',
    eta: 'Q3 2026',
  },
  {
    category: 'Regelgeving',
    title: 'NEN 7510 uitgelegd voor zorgbestuurders',
    body: 'Geen jargon, wel concrete bestuurs-aansprakelijkheid. Wat is een control en wat doet uw leverancier daadwerkelijk?',
    eta: 'Q3 2026',
  },
  {
    category: 'Regelgeving',
    title: 'NIS2 (Cbw) voor de zorg: bent u een aangewezen entiteit?',
    body: 'Annex I "Health" classificatie, sub-sector segmentering, en hoe Nis2Care de compliance-overlay levert naast uw EPD.',
    eta: 'Q2 2026',
  },
  {
    category: 'Standaarden',
    title: 'FHIR R4 in NL-zorg: wat is wel en wat niet beschikbaar?',
    body: 'Patient, Encounter, Observation, MedicationRequest — wat is de Nederlandse profiel-realiteit en waar zitten de gaten?',
    eta: 'Q3 2026',
  },
  {
    category: 'Standaarden',
    title: 'Wegiz en eOverdracht: de praktische gids voor implementatie',
    body: 'BgZ-bundel, Nuts-aansluiting, ketentest. Stap-voor-stap zonder de marketing-fluff.',
    eta: 'Q4 2026',
  },
  {
    category: 'Declaratie',
    title: 'iWmo retourcodes: een veldgids',
    body: 'De top 20 retourcodes, wat ze betekenen, en hoe ze te voorkomen aan de bron in plaats van te repareren bij declaratie.',
    eta: 'Q3 2026',
  },
];

const categories = Array.from(new Set(plannedArticles.map((a) => a.category)));
---
<Base
  title="Kennisbank — Sindzo"
  description="Onafhankelijke uitleg over zorgregelgeving (Wtza, NIS2, NEN 7510), interoperabiliteit (FHIR, Wegiz) en declaratie. Voor zorgbestuurders, FG's en CIO's."
>
  <PageHero
    eyebrow="Kennisbank"
    title="Kennis vóór de sales-pitch."
    subtitle="Wij publiceren eerlijke uitleg over zorgregelgeving en interoperabiliteit — onafhankelijk van of u Sindzo afneemt. Een leverancier die kennis deelt verdient eerder vertrouwen dan eentje die het verbergt."
  >
    <div slot="actions" class="flex flex-wrap gap-3">
      <a href="#aankondiging" class="btn-primary no-underline">Krijg een seintje bij publicatie</a>
      <a href="/contact" class="btn-secondary no-underline">Suggereer een onderwerp</a>
    </div>
  </PageHero>

  <section class="container-prose py-12 border-b border-ink-100 bg-ink-100/40">
    <div class="rounded-xl border border-amber-200 bg-amber-50/60 p-6 max-w-3xl">
      <div class="text-[10px] font-extrabold uppercase tracking-[0.22em] text-amber-900">In voorbereiding</div>
      <p class="mt-2 text-sm text-ink-700 leading-relaxed">
        De Kennisbank gaat live met de eerste artikelen in Q2–Q3 2026. Hieronder de onderwerpen die wij eerst publiceren —
        gekozen op basis van wat onze early-access-partners ons vroegen. Mist u een onderwerp? Mail naar
        <a href="mailto:kennisbank@sindzo.nl" class="text-sindzo-700 hover:underline">kennisbank@sindzo.nl</a>.
      </p>
    </div>
  </section>

  {categories.map((cat) => (
    <section class="container-prose py-14 border-b border-ink-100 last:border-0">
      <h2 class="font-display text-2xl font-bold text-ink-900">{cat}</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {plannedArticles.filter((a) => a.category === cat).map((a) => (
          <article class="rounded-xl border border-ink-100 bg-white p-5 opacity-80">
            <div class="flex items-center justify-between">
              <span class="text-[10px] uppercase tracking-wider text-ink-500">Verwacht {a.eta}</span>
              <span class="status-dot bg-amber-500"></span>
            </div>
            <h3 class="mt-3 font-display text-base font-semibold text-ink-900">{a.title}</h3>
            <p class="mt-2 text-sm text-ink-700 leading-snug">{a.body}</p>
          </article>
        ))}
      </div>
    </section>
  ))}

  <section id="aankondiging" class="container-prose py-16">
    <div class="rounded-2xl border border-ink-200 bg-ink-100/50 p-8 sm:p-12">
      <h2 class="font-display text-2xl font-bold text-ink-900">Krijg een seintje bij publicatie</h2>
      <p class="mt-3 max-w-2xl text-ink-700">
        Niet meer dan één e-mail per maand, geen marketing-druk. Uitschrijven kan in één klik.
        Stuur een mail met onderwerp "kennisbank-update" naar
        <a href="mailto:kennisbank@sindzo.nl?subject=kennisbank-update" class="text-sindzo-700 hover:underline">kennisbank@sindzo.nl</a> —
        wij zetten u op de lijst zonder verder gedoe.
      </p>
    </div>
  </section>

  <Cta />
</Base>
