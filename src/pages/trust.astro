---
import Base from '../layouts/Base.astro';

// Trust Centre — kerncompetentie t.o.v. concurrenten die deze info pas in
// tender-fase delen. Eerlijke status, niet marketing-spraak. Iedere claim
// linkt naar onderbouwing (zodra documenten publiek beschikbaar zijn).
//
// Status-conventie:
//   live    — aantoonbaar nu, document beschikbaar
//   wip     — in afronding met concrete tijdslijn
//   roadmap — gepland maar nog niet gestart

const pillars = [
  {
    key: 'security',
    title: 'Informatiebeveiliging',
    intro: 'NEN 7510-werkdocument is leidend. Pen-tests jaarlijks via NL-CERT-aangesloten partij.',
    items: [
      { label: 'NEN 7510:2024', status: 'wip', note: 'Werkdocument compleet, externe audit Q4 2026', doc: '#nen7510' },
      { label: 'NEN 7512 (uitwisseling)', status: 'wip', note: 'Toegepast op FHIR-/LSP-koppelingen', doc: '#nen7512' },
      { label: 'NEN 7513 (logging)', status: 'live', note: 'Onveranderbare auditlog, 7 jaar bewaartermijn', doc: '#nen7513' },
      { label: 'ISO 27001', status: 'roadmap', note: 'Audit gepland 2027', doc: '#iso27001' },
      { label: 'Pentest jaarlijks', status: 'live', note: 'Rapport beschikbaar onder NDA', doc: '#pentest' },
      { label: 'Encryptie at-rest', status: 'live', note: 'AES-256-GCM per tenant-sleutel', doc: '#encryption' },
    ],
  },
  {
    key: 'privacy',
    title: 'Privacy & gegevensbescherming',
    intro: 'AVG-conform met expliciete verwerkers-rolverdeling. PII (BSN, AGB) altijd encrypted.',
    items: [
      { label: 'AVG / GDPR', status: 'live', note: 'Standaard-DPA beschikbaar in 4 talen', doc: '#dpa' },
      { label: 'Verwerkersovereenkomst', status: 'live', note: 'PDF + Word, geen NDA nodig', doc: '/documenten/dpa-sindzo-2026.pdf' },
      { label: 'Subverwerkers-overzicht', status: 'live', note: '12 subverwerkers, alle in EER', doc: '#subverwerkers' },
      { label: 'DPIA-template', status: 'live', note: 'Voor zorgaanbieder eigen DPIA', doc: '/documenten/dpia-template.pdf' },
      { label: 'BSN-encryptie', status: 'live', note: 'AES-256-GCM, key rotation per kwartaal', doc: '#bsn' },
      { label: 'Recht op vergetelheid', status: 'live', note: 'Pseudonimisering + audit-trail', doc: '#vergetelheid' },
    ],
  },
  {
    key: 'interop',
    title: 'Interoperabiliteit & openheid',
    intro: 'Open API\'s, FHIR-endpoints en publieke koppeldocumentatie. Geen vendor lock-in.',
    items: [
      { label: 'FHIR R4', status: 'live', note: 'Patient, Encounter, Observation, MedicationRequest', doc: 'https://api.sindzo.nl/docs' },
      { label: 'MedMij', status: 'wip', note: 'Aansluiting in afrondingsfase Q3 2026', doc: '#medmij' },
      { label: 'Wegiz / eOverdracht', status: 'wip', note: 'eOverdracht-bundle BgZ-conform', doc: '#wegiz' },
      { label: 'LSP', status: 'live', note: 'Via VZVZ-gateway, opt-in per cliënt', doc: '#lsp' },
      { label: 'Open API', status: 'live', note: 'OpenAPI 3.1, gratis sandbox', doc: 'https://api.sindzo.nl' },
      { label: 'Data-export', status: 'live', note: 'Volledige export in JSON/CSV op verzoek', doc: '#export' },
    ],
  },
  {
    key: 'operations',
    title: 'Operationele continuïteit',
    intro: 'NL-hosting, transparante uptime, publieke status-page en herstelplan getest.',
    items: [
      { label: 'NL-hosting', status: 'live', note: 'Azure West-Europe + backup NL', doc: '#hosting' },
      { label: 'Uptime SLA', status: 'live', note: '99,9% productie, gemeten extern', doc: 'https://status.sindzo.nl' },
      { label: 'Statuspagina publiek', status: 'live', note: 'Incidenten + onderhoudsvensters', doc: 'https://status.sindzo.nl' },
      { label: 'BCM-test', status: 'live', note: 'Jaarlijkse restore-oefening', doc: '#bcm' },
      { label: 'RPO / RTO', status: 'live', note: 'RPO 1 uur, RTO 4 uur', doc: '#rto' },
      { label: 'Exit-procedure', status: 'live', note: 'Contractueel vastgelegd in MSA', doc: '#exit' },
    ],
  },
  {
    key: 'regulatory',
    title: 'Wettelijke kaders & sectorregels',
    intro: 'Wkkgz, Wzd, Wtza, Wtta en de Cyberbeveiligingswet — actief gevolgd, niet afgewacht.',
    items: [
      { label: 'Cbw (NIS2)', status: 'wip', note: 'Voorbereidingen voor 1 juli 2026', doc: '#cbw' },
      { label: 'Wkkgz-klachtenregeling', status: 'live', note: 'Module + workflow standaard', doc: '#wkkgz' },
      { label: 'Wzd-stappenplan', status: 'live', note: 'Halfjaarlijkse IGJ-XML', doc: '#wzd' },
      { label: 'Wtza-jaarverantwoording', status: 'live', note: 'Wizard voor deadline 31 mei', doc: '#wtza' },
      { label: 'Wtta-uitlenersregister', status: 'wip', note: 'Klaar voor 1-1-2027', doc: '#wtta' },
      { label: 'AI Act high-risk', status: 'roadmap', note: 'Classificatie + register tegen 2 dec 2027', doc: '#ai-act' },
    ],
  },
];

const dot = (s: string) =>
  s === 'live' ? 'bg-green-500' : s === 'wip' ? 'bg-amber-500' : 'bg-ink-300';

const statusLabel = (s: string) =>
  s === 'live' ? 'Aantoonbaar' : s === 'wip' ? 'In afronding' : 'Op roadmap';
---
<Base
  title="Trust Centre — Sindzo"
  description="Eerlijke status van onze compliance, security, privacy en interoperabiliteit. Geen NDA nodig om dit te lezen."
>
  <section class="border-b border-ink-100 bg-gradient-to-b from-sindzo-50 to-white">
    <div class="container-prose py-16 sm:py-20">
      <span class="badge mb-5">Trust Centre · laatst herzien {new Date().toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
      <h1 class="font-display text-4xl font-bold tracking-tightish text-ink-900 sm:text-5xl max-w-3xl">
        Compliance op tafel, niet in een PDF achter een NDA.
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-ink-700">
        Inkoop, FG, CISO en bestuur kunnen Sindzo beoordelen vóór er een gesprek nodig is.
        Elk item hieronder heeft een eerlijke status — groen, geel of grijs — met onderbouwing.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-4 text-sm">
        <a href="/documenten/security-pack-2026.zip" class="btn-primary no-underline">Download security-pack</a>
        <a href="/documenten/dpa-sindzo-2026.pdf" class="btn-secondary no-underline">DPA-PDF</a>
        <a href="https://status.sindzo.nl" class="text-sindzo-700 font-medium no-underline hover:underline">Live status →</a>
      </div>
      <p class="mt-6 text-xs text-ink-500">
        <span class="status-dot bg-green-500"></span> aantoonbaar nu
        <span class="status-dot bg-amber-500 ml-4"></span> in afronding (met datum)
        <span class="status-dot bg-ink-300 ml-4"></span> op roadmap
      </p>
    </div>
  </section>

  {pillars.map((pillar) => (
    <section id={pillar.key} class="container-prose py-14 border-b border-ink-100 last:border-0">
      <div class="grid gap-10 md:grid-cols-[260px_1fr]">
        <div>
          <h2 class="font-display text-2xl font-bold text-ink-900">{pillar.title}</h2>
          <p class="mt-3 text-sm text-ink-700 leading-relaxed">{pillar.intro}</p>
        </div>
        <ul class="grid gap-3 sm:grid-cols-2">
          {pillar.items.map((item) => (
            <li class="rounded-lg border border-ink-100 bg-white p-4">
              <div class="flex items-start gap-3">
                <span class={`status-dot mt-1.5 shrink-0 ${dot(item.status)}`}></span>
                <div class="flex-1">
                  <div class="flex items-center justify-between gap-3">
                    <span class="font-semibold text-ink-900 text-sm">{item.label}</span>
                    <span class="text-[10px] uppercase tracking-wider text-ink-500">{statusLabel(item.status)}</span>
                  </div>
                  <p class="mt-1 text-xs text-ink-500 leading-snug">{item.note}</p>
                  <a href={item.doc} class="mt-2 inline-block text-xs font-medium text-sindzo-700 no-underline hover:underline">
                    Onderbouwing →
                  </a>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ))}

  <section class="container-prose py-16">
    <div class="rounded-2xl border border-ink-200 bg-ink-100/50 p-8 sm:p-12">
      <h2 class="font-display text-2xl font-bold text-ink-900">Iets niet duidelijk?</h2>
      <p class="mt-3 max-w-2xl text-ink-700">
        Stuur een vraag rechtstreeks naar onze FG of security-lead. Reactie binnen 1 werkdag.
        Voor due-diligence-vragen accepteren we standaard vragenlijsten (CAIQ, SIG, BSI C5).
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="mailto:trust@sindzo.nl" class="btn-primary no-underline">trust@sindzo.nl</a>
        <a href="/contact" class="btn-secondary no-underline">Stuur vragenlijst</a>
      </div>
    </div>
  </section>
</Base>
