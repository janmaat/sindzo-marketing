---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import Cta from '../components/Cta.astro';

// Productvergelijking met de top-3 NL-concurrenten in VVT/GHZ.
// Bewust feitelijk: peildatum + bron per bestreden claim. Eerlijk
// over waar concurrenten voorlopen — bouwt geloofwaardigheid voor
// de win-claims.
//
// Onderhoud: claims minstens 1x per kwartaal hercontroleren tegen
// publieke leverancier-sites + ervaring van early-access-partners.

const lastReviewed = '2026-05-29';

interface Cell {
  status: 'yes' | 'no' | 'partial' | 'unknown';
  note?: string;
}
interface Row {
  feature: string;
  detail?: string;
  sindzo: Cell;
  nedap: Cell;
  pinkroccade: Cell;
  pluriform: Cell;
  source?: string;
}
interface Group {
  title: string;
  intro: string;
  tone: 'win' | 'parity' | 'gap';
  rows: Row[];
}

const groups: Group[] = [
  {
    title: 'Waar Sindzo bewezen vooruitloopt',
    intro: 'Marktscan 2026-05-29: geen directe NL-concurrent biedt deze functies. Eén concurrent (ChipSoft HiX) heeft NL+EN-portaal maar alleen voor ziekenhuis-segment, niet voor VVT/GHZ.',
    tone: 'win',
    rows: [
      {
        feature: 'Meertalig cliëntportaal',
        detail: 'NL/EN/TR/AR/DE + PL/UK',
        sindzo: { status: 'yes', note: '7 talen live' },
        nedap: { status: 'no', note: 'NL-only (Caren-portaal)' },
        pinkroccade: { status: 'no', note: 'NL-only (myNeva-portaal)' },
        pluriform: { status: 'no', note: 'NL-only' },
        source: 'Eigen marktscan + leveranciers-sites — peildatum 2026-05-29',
      },
      {
        feature: 'Collega-netwerk medewerker',
        detail: 'Buddy-/intervisie-matching gescheiden van HR',
        sindzo: { status: 'yes', note: 'Live' },
        nedap: { status: 'no', note: 'Geen peer-functie in Ons-suite' },
        pinkroccade: { status: 'no' },
        pluriform: { status: 'no' },
        source: 'Deep-research USP-prompts; NL-aanbieders + Speakap (generiek intranet)',
      },
      {
        feature: 'Lotgenoten-support op welzijnsthema',
        detail: 'Vertrouwelijke peer-support op werkdruk/burn-out/rouw',
        sindzo: { status: 'yes', note: 'Live na DPIA-afronding' },
        nedap: { status: 'no' },
        pinkroccade: { status: 'no' },
        pluriform: { status: 'no' },
        source: 'NHS RISE (PSNet AHRQ) buitenlands bewijs; geen NL-equivalent gevonden',
      },
    ],
  },
  {
    title: 'Functionele pariteit met marktleider',
    intro: 'Hier kunt u erop rekenen dat Sindzo niet achterloopt op wat marktleiders bieden. Geen kwalitatieve uitspraken over wie "beter" is — claims zijn ja/nee.',
    tone: 'parity',
    rows: [
      {
        feature: 'FHIR R4-architectuur met Zib-profielen',
        sindzo: { status: 'partial', note: '8 Zibs intern actief; publieke REST API Q4 2026' },
        nedap: { status: 'partial', note: 'Open API, FHIR-subset' },
        pinkroccade: { status: 'partial' },
        pluriform: { status: 'unknown' },
      },
      {
        feature: 'AI-pre-fill + spraakinvoer SOEP',
        sindzo: { status: 'yes', note: 'Live, met audit-trail' },
        nedap: { status: 'yes', note: 'Toediening + rapportage via voice' },
        pinkroccade: { status: 'partial' },
        pluriform: { status: 'partial' },
      },
      {
        feature: 'NL-hosting (EER-gebonden)',
        sindzo: { status: 'yes', note: 'Azure West-Europe + NL backup' },
        nedap: { status: 'yes' },
        pinkroccade: { status: 'yes' },
        pluriform: { status: 'yes' },
      },
      {
        feature: 'BSN-encryptie per-tenant',
        sindzo: { status: 'yes', note: 'AES-256-GCM + HKDF' },
        nedap: { status: 'unknown' },
        pinkroccade: { status: 'unknown' },
        pluriform: { status: 'unknown' },
        source: 'Concurrent-implementaties niet publiek gedocumenteerd',
      },
      {
        feature: 'SMART-doelen + risicoprofielen-engine',
        detail: 'Cliëntformulering, streefdatum, val/decubitus/ondervoeding/delier autosignalering',
        sindzo: { status: 'yes', note: 'Band A live sinds mei 2026' },
        nedap: { status: 'partial', note: 'SMART-doelen ja, autosignalering deels' },
        pinkroccade: { status: 'partial' },
        pluriform: { status: 'partial' },
      },
      {
        feature: 'Modulair geprijsd (geen all-in-one)',
        sindzo: { status: 'yes' },
        nedap: { status: 'partial', note: 'Modules opt-in maar bundling-druk' },
        pinkroccade: { status: 'partial' },
        pluriform: { status: 'partial' },
      },
      {
        feature: 'eOverdracht (Wegiz-BgZ)',
        sindzo: { status: 'partial', note: 'BgZ klaar, Nuts-aansluiting in afronding' },
        nedap: { status: 'yes' },
        pinkroccade: { status: 'yes' },
        pluriform: { status: 'partial' },
      },
    ],
  },
  {
    title: 'Waar concurrenten (terecht) voorlopen',
    intro: 'Eerlijk: drie technische/compliance-punten waar gevestigde leveranciers op dit moment verder zijn dan Sindzo. Allemaal op de roadmap met concrete deadlines.',
    tone: 'gap',
    rows: [
      {
        feature: 'Interventie-catalog (zorgplan)',
        detail: 'Aantal kant-en-klare interventie-templates',
        sindzo: { status: 'partial', note: '47 — Band A-uitbreiding' },
        nedap: { status: 'yes', note: '~187' },
        pinkroccade: { status: 'yes', note: '~120' },
        pluriform: { status: 'yes', note: '~140' },
        source: 'Band A ADR 2026-05-16 — competitive assessment',
      },
      {
        feature: 'ISO 27001-certificering',
        sindzo: { status: 'no', note: 'Op roadmap, audit gepland 2027' },
        nedap: { status: 'yes' },
        pinkroccade: { status: 'yes' },
        pluriform: { status: 'yes' },
      },
      {
        feature: 'NEN 7510:2024 extern geaudit',
        sindzo: { status: 'partial', note: 'Werkdocument klaar, audit Q4 2026' },
        nedap: { status: 'yes' },
        pinkroccade: { status: 'yes' },
        pluriform: { status: 'yes' },
      },
    ],
  },
];

const cellSymbol = (s: string) =>
  s === 'yes' ? '✓' : s === 'partial' ? '◐' : s === 'no' ? '✗' : '?';

const cellColor = (s: string) =>
  s === 'yes' ? 'text-green-700 bg-green-50' :
  s === 'partial' ? 'text-amber-700 bg-amber-50' :
  s === 'no' ? 'text-rose-700 bg-rose-50' :
  'text-ink-500 bg-ink-100/50';

const cellLabel = (s: string) =>
  s === 'yes' ? 'Ja' :
  s === 'partial' ? 'Deels / wip' :
  s === 'no' ? 'Nee' :
  'Onbekend';

const groupTone = (t: string) =>
  t === 'win' ? 'border-l-4 border-accent-500' :
  t === 'gap' ? 'border-l-4 border-amber-400' :
  'border-l-4 border-ink-200';

const dateNl = new Date(lastReviewed).toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' });
---
<Base
  title="Productvergelijking — Sindzo vs Nedap Ons, PinkRoccade en Pluriform | Sindzo"
  description="Eerlijke vergelijking van Sindzo met de top-3 NL-VVT/GHZ-concurrenten. Per claim een peildatum en bron, inclusief eerlijke vermelding waar concurrenten voorlopen."
>
  <PageHero
    eyebrow="Productvergelijking"
    title="Sindzo naast de gevestigde marktleiders — feitelijk."
    subtitle="Inkopers willen weten: wat hebben wij wel of niet ten opzichte van Nedap Ons, PinkRoccade myNeva en Pluriform Zorg? Hieronder de feiten, mét de plekken waar concurrenten ouder, groter en verder zijn. Géén kwalitatieve oordelen."
  >
    <div slot="actions" class="flex flex-wrap gap-3">
      <a href="/demo" class="btn-primary no-underline">Vraag demo aan</a>
      <a href="/trust" class="btn-secondary no-underline">Trust Centre</a>
    </div>
  </PageHero>

  <section class="border-y border-amber-200 bg-amber-50 py-6">
    <div class="container-prose">
      <p class="text-sm text-amber-900">
        <strong>Laatst gecheckt: {dateNl}.</strong>
        Bronnen: eigen marktscan tegen publieke leverancier-websites, productdemonstraties, en gesprekken met inkopers.
        Klopt er iets niet meer? Mail <a href="mailto:trust@sindzo.nl?subject=Correctie%20vergelijkingspagina" class="text-sindzo-700 hover:underline">trust@sindzo.nl</a> —
        we corrigeren binnen 1 werkdag en plaatsen een revisie-notitie. Vergelijking is bedoeld als informatief naslagwerk, niet als kwalitatief
        oordeel over concurrenten.
      </p>
    </div>
  </section>

  {groups.map((g) => (
    <section class={`container-prose py-12 border-b border-ink-100 last:border-0`}>
      <div class={`pl-5 ${groupTone(g.tone)} mb-8`}>
        <h2 class="font-display text-2xl font-bold text-ink-900 sm:text-3xl">{g.title}</h2>
        <p class="mt-2 text-sm text-ink-700 max-w-3xl">{g.intro}</p>
      </div>

      <div class="overflow-x-auto rounded-xl border border-ink-100 bg-white">
        <table class="w-full text-sm">
          <thead class="bg-ink-100/50 text-left text-xs uppercase tracking-wider text-ink-500">
            <tr>
              <th class="px-4 py-3 font-semibold min-w-[240px]">Functie</th>
              <th class="px-4 py-3 font-semibold text-center min-w-[110px]"><span class="text-sindzo-900">Sindzo</span></th>
              <th class="px-4 py-3 font-semibold text-center min-w-[110px]">Nedap Ons</th>
              <th class="px-4 py-3 font-semibold text-center min-w-[110px]">PinkRoccade myNeva</th>
              <th class="px-4 py-3 font-semibold text-center min-w-[110px]">Pluriform Zorg</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-ink-100">
            {g.rows.map((r) => (
              <>
                <tr>
                  <td class="px-4 py-3 align-top">
                    <div class="font-semibold text-ink-900">{r.feature}</div>
                    {r.detail && <div class="text-xs text-ink-500 mt-0.5 leading-snug">{r.detail}</div>}
                  </td>
                  {[r.sindzo, r.nedap, r.pinkroccade, r.pluriform].map((c) => (
                    <td class="px-4 py-3 align-top text-center">
                      <div class={`inline-flex flex-col items-center gap-1 rounded-md px-2 py-1.5 ${cellColor(c.status)}`}>
                        <span class="text-lg font-bold leading-none">{cellSymbol(c.status)}</span>
                        <span class="text-[10px] uppercase tracking-wider font-semibold leading-none">{cellLabel(c.status)}</span>
                      </div>
                      {c.note && <div class="mt-1 text-[11px] text-ink-500 leading-tight max-w-[140px] mx-auto">{c.note}</div>}
                    </td>
                  ))}
                </tr>
                {r.source && (
                  <tr>
                    <td colspan="5" class="px-4 pb-3 -mt-2 text-[11px] text-ink-500 italic">
                      Bron: {r.source}
                    </td>
                  </tr>
                )}
              </>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  ))}

  <section class="container-prose py-12 border-t border-ink-100">
    <div class="max-w-3xl mb-8">
      <span class="eyebrow">Marktscan — bredere context</span>
      <h2 class="mt-3 font-display text-2xl font-bold text-ink-900 sm:text-3xl">
        En de overige NL-VVT/GHZ-leveranciers?
      </h2>
      <p class="mt-3 text-sm text-ink-700">
        Hetzelfde patroon dat de top-3 in beeld brengt herhaalt zich in de bredere markt.
        Op de twee belangrijkste differentiatie-assen — meertalig cliëntportaal en peer-support voor
        medewerkers — komt geen Nederlandse VVT/GHZ-leverancier verder dan Sindzo. Onder per leverancier
        kort de bevinding (peildatum {dateNl}).
      </p>
    </div>
    <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {[
        { name: 'Cura', maker: 'PinkRoccade', portaal: 'NL-only', peer: 'Geen peer-support medewerker' },
        { name: 'Plancare 2', maker: 'Plancare', portaal: 'NL-only', peer: 'Geen peer-support medewerker' },
        { name: 'Carit Care', maker: 'Carit', portaal: 'NL-only', peer: 'Geen peer-support medewerker' },
        { name: 'Quli', maker: 'Quli (zelfstandig cliëntportaal)', portaal: 'NL-only', peer: 'n.v.t. — geen medewerker-app' },
        { name: 'Famped / Famedio', maker: 'Famedio', portaal: 'NL-only', peer: 'Geen peer-support medewerker' },
        { name: 'mijnCaress', maker: 'PinkRoccade', portaal: 'NL-only', peer: 'Geen peer-support medewerker' },
      ].map((v) => (
        <li class="rounded-xl border border-ink-100 bg-white p-5">
          <h3 class="font-display text-base font-semibold text-ink-900">{v.name}</h3>
          <p class="text-xs text-ink-500 mt-0.5">{v.maker}</p>
          <dl class="mt-4 space-y-2 text-xs">
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-wider text-ink-500">Meertalig portaal</dt>
              <dd class="mt-0.5 text-ink-700 flex items-center gap-1"><span class="text-rose-600 font-bold">✗</span> {v.portaal}</dd>
            </div>
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-wider text-ink-500">Peer-support medewerker</dt>
              <dd class="mt-0.5 text-ink-700 flex items-center gap-1"><span class="text-rose-600 font-bold">✗</span> {v.peer}</dd>
            </div>
          </dl>
        </li>
      ))}
    </ul>
    <p class="mt-6 text-xs text-ink-500 max-w-3xl">
      Bronnen: leveranciers-websites + ADR 2026-05-29 Sindzo-meertaligheid + deep-research USP-prompts.
      Volledige feature-vergelijking met deze leveranciers op aanvraag —
      <a href="mailto:vergelijking@sindzo.nl?subject=Uitgebreide%20vergelijking" class="text-sindzo-700 hover:underline">vergelijking@sindzo.nl</a>.
    </p>
  </section>

  <section class="container-prose py-12 border-t border-ink-100">
    <div class="grid gap-8 md:grid-cols-2">
      <div class="rounded-xl border border-ink-100 bg-white p-6">
        <h3 class="font-display text-lg font-semibold text-ink-900">Hoe wij dit onderhouden</h3>
        <ul class="mt-3 space-y-2 text-sm text-ink-700">
          <li>• Hercheck minimaal 1× per kwartaal tegen publieke productpagina's</li>
          <li>• Feature-claims uit verkoopgesprekken bij early-access-partners</li>
          <li>• Revisie-notities onderaan elke wijziging</li>
          <li>• Géén anonieme bronnen — alleen wat publiek of via demo te verifiëren is</li>
        </ul>
      </div>
      <div class="rounded-xl border border-ink-100 bg-sindzo-50 p-6">
        <h3 class="font-display text-lg font-semibold text-ink-900">Vergelijking aanvragen met andere leverancier?</h3>
        <p class="mt-3 text-sm text-ink-700">
          Werkt u op dit moment met Cura, Plancare 2, Carit Care, mijnCaress of een ander pakket
          dat hier niet staat? Mail de naam en we sturen een feitelijke side-by-side toe binnen 1 werkdag.
        </p>
        <a href="mailto:vergelijking@sindzo.nl?subject=Vergelijking%20aanvragen" class="mt-4 inline-block text-sm font-medium text-sindzo-700 hover:underline">
          vergelijking@sindzo.nl →
        </a>
      </div>
    </div>
  </section>

  <RelatedArticles
    title="Onderbouwing van de white-space-claims"
    intro="Sceptisch over de twee dimensies waar Sindzo bewezen vooruitloopt? Hieronder de bron-artikelen — feitelijk, gesourced, met peildatum."
    articles={[
      {
        eyebrow: 'Standaarden + marktanalyse',
        title: 'Waarom geen NL-VVT/GHZ-leverancier meertalig is',
        body: 'De marktscan-tabel uitgebreid: 9 leveranciers, demografische context (CBS), en 4 redenen waarom niemand het doet.',
        href: '/kennisbank/meertalig-clientportaal-nl-zorg',
      },
      {
        eyebrow: 'Arbeidsmarkt + welzijn',
        title: 'Peer-support voor zorgmedewerkers — wat het onderzoek echt zegt',
        body: 'Vijf buitenlandse studies uitgewerkt (NHS RISE, IRT, AHRQ, IEW, Incredible Health). Plus de vier ontwerp-eisen voor werkend peer-support.',
        href: '/kennisbank/peer-support-zorgmedewerkers',
      },
    ]}
  />

  <Cta
    title="Klaar voor een demo met deze tabel ernaast?"
    subtitle="Wij doorlopen de vergelijking tijdens de demo en tonen elk genoemd punt live in het systeem — of zijn eerlijk over waar het nog op de roadmap staat."
  />
</Base>
