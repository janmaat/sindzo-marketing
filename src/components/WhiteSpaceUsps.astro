---
// Drie features waar marktscan (peildatum 2026-05-29) bewijst dat geen
// directe NL-concurrent ze biedt. Bewust met bron-citaten: zorgbestuurders
// die hier sceptisch zijn, kunnen het natrekken.
//
// Status-conventie matchet de rest van de site:
//   live    — beschikbaar in productie
//   wip     — in afronding (datum/release zichtbaar)
//   roadmap — gepland, nog niet gestart

const usps = [
  {
    eyebrow: 'Meertalig cliëntportaal',
    title: '7 talen in het cliëntportaal — voor de hele familie',
    body: 'NL, EN, TR, AR, DE in fase 1a · PL en UK direct daarna. Bedoeld voor 1e-generatie Turkse/Marokkaanse VVT-ouderen, vluchtelingen­gezinnen en mantelzorgers buiten Nederland.',
    evidence: 'Marktscan 2026-05-29 — Nedap Ons + Caren, PinkRoccade myNeva, Cura, Carit, Plancare 2, Salar BeFlex, Quli en Famped/Famedio zijn allemaal NL-only. ChipSoft levert NL+EN maar alleen in HiX (ziekenhuis-segment).',
    status: 'live',
    statusNote: 'Beschikbaar nu',
  },
  {
    eyebrow: 'Collega-netwerk',
    title: 'Buddy- en intervisie-matching voor zorgmedewerkers',
    body: 'Zelf-aanmelden voor een onboarding-buddy, internationale-instroom-buddy of intervisie-partner. Strikt gescheiden van HR — geen manager-inzage. Geen welzijns-/gezondheidsdata in fase 1.',
    evidence: 'Geen NL-concurrent biedt peer-matching (Nedap Ons heeft het niet, Speakap is generiek intranet). Buitenlands bewijs: NHS Employers + PSNet AHRQ "RISE" tonen 20% retentie-effect bij gestructureerde peer-support.',
    status: 'live',
    statusNote: 'Beschikbaar nu',
  },
  {
    eyebrow: 'Zorgplan op niveau van marktleider',
    title: 'SMART-doelen, risicoprofielen en cliëntperspectief — native',
    body: 'Cliëntformulering en mantelzorgperspectief naast professionele formulering. Risicoprofielen-engine (val/decubitus/ondervoeding/delier) draait automatisch op metingen en vragenlijsten. SMART-doelen met status-flow en streefdatum.',
    evidence: 'Band A-uitbreiding (2026-05-16) tilde Sindzo van pariteit met oude generatie ECD\'s naar marktleider-niveau 2024-2026 (Nedap, Pluriform, PUUR, Mextra, Carenzorgt). Inclusief Wcz/NEN 7510:2024 cliëntportaal-zichtbaarheid.',
    status: 'live',
    statusNote: 'Beschikbaar nu',
  },
];

const statusColor = (s: string) =>
  s === 'live' ? 'bg-green-500' : s === 'wip' ? 'bg-amber-500' : 'bg-ink-300';
const statusLabel = (s: string) =>
  s === 'live' ? 'Live' : s === 'wip' ? 'In afronding' : 'Op roadmap';
---
<section class="container-prose py-20 border-t border-ink-100">
  <div class="max-w-3xl">
    <span class="eyebrow">Wat concurrenten niet hebben</span>
    <h2 class="mt-3 font-display text-3xl font-bold tracking-tightish text-ink-900 sm:text-4xl">
      Drie functies die de Nederlandse <em class="italic font-semibold text-accent-600">VVT/GHZ-markt</em> nu mist.
    </h2>
    <p class="mt-3 text-ink-700">
      Geen marketing-spraak: we benoemen expliciet welke concurrenten we tegen welke peildatum
      hebben getoetst. Heeft een leverancier dit inmiddels toch? Laat het weten —
      <a href="mailto:trust@sindzo.nl" class="text-sindzo-700 hover:underline">trust@sindzo.nl</a>.
    </p>
  </div>

  <ul class="mt-12 grid gap-6 md:grid-cols-3">
    {usps.map((u) => (
      <li class="flex flex-col rounded-xl border border-ink-200 bg-white p-6">
        <div class="flex items-center gap-2">
          <span class={`inline-block h-2 w-2 rounded-full ${statusColor(u.status)}`}></span>
          <span class="text-[10px] font-bold uppercase tracking-[0.18em] text-ink-500">{statusLabel(u.status)} · {u.statusNote}</span>
        </div>
        <div class="mt-4 text-xs font-bold uppercase tracking-[0.18em] text-accent-700">{u.eyebrow}</div>
        <h3 class="mt-2 font-display text-lg font-semibold text-ink-900 leading-snug">{u.title}</h3>
        <p class="mt-3 text-sm text-ink-700 leading-relaxed flex-1">{u.body}</p>
        <div class="mt-5 rounded-lg border border-ink-100 bg-ink-100/40 p-3">
          <div class="text-[10px] font-bold uppercase tracking-wider text-ink-500 mb-1">Marktbewijs</div>
          <p class="text-xs text-ink-700 leading-snug">{u.evidence}</p>
        </div>
      </li>
    ))}
  </ul>
</section>
