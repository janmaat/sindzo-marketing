---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';

// Bewust eerlijke empty-state. Wij hebben geen cases om te delen totdat
// onze early-access partners hun verhaal willen vertellen — verzonnen of
// algemene "een grote zorgaanbieder uit Nederland"-cases voegen niets toe.
---
<Base
  title="Klantcases — Coheza"
  description="Cases van zorgorganisaties die met Coheza werken — gepubliceerd zodra onze early-access partners hun verhaal willen delen."
>
  <PageHero
    eyebrow="Klantcases"
    title="Cases volgen — zodra onze early-access partners hun verhaal willen delen."
    subtitle="Wij geloven niet in verzonnen of geanonimiseerde 'een grote zorgaanbieder uit Nederland'-cases. Geen genoeg om te delen ≠ geen klanten — het betekent dat wij onze klanten niet onder druk zetten om referent te zijn vóór ze zelf vinden dat er iets te vertellen valt."
  />

  <section class="container-prose py-16">
    <div class="grid gap-8 md:grid-cols-2">
      <div class="rounded-2xl border border-ink-100 bg-white p-8">
        <h2 class="font-display text-xl font-semibold text-ink-900">Wat we wél kunnen tonen</h2>
        <p class="mt-3 text-ink-700">
          Onze status, architectuur, integraties en compliance staan op:
        </p>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href="/trust" class="text-sindzo-700 hover:underline">/trust</a> — eerlijke status per compliance-kader</li>
          <li><a href="/integraties" class="text-sindzo-700 hover:underline">/integraties</a> — wat live is en wat in afronding</li>
          <li><a href="/oplossing" class="text-sindzo-700 hover:underline">/oplossing</a> — modules met live/wip-stoplichten</li>
          <li><a href="/procurement" class="text-sindzo-700 hover:underline">/procurement</a> — DPA, security-pack, architectuur</li>
        </ul>
      </div>

      <div class="rounded-2xl border border-ink-100 bg-sindzo-50 p-8">
        <h2 class="font-display text-xl font-semibold text-ink-900">Wilt u zelf eerst praten met een early-access partner?</h2>
        <p class="mt-3 text-ink-700">
          Wij kunnen u in contact brengen met een organisatie die Coheza al gebruikt — met hun
          uitdrukkelijke toestemming, voor een gesprek tussen u en hen direct. Geen scripted
          ervaringen, geen scheidsrechter.
        </p>
        <a href="/contact" class="mt-5 inline-block btn-primary no-underline">Vraag een referentie-call aan</a>
      </div>
    </div>

    <div class="mt-16 rounded-2xl border border-ink-100 bg-ink-100/50 p-8">
      <h3 class="font-display text-lg font-semibold text-ink-900">Bent u zelf early-access partner en wilt u uw verhaal vertellen?</h3>
      <p class="mt-3 text-sm text-ink-700 max-w-2xl">
        Wij maken samen met u een case-tekst, u keurt elke alinea af, en hij wordt pas
        gepubliceerd als u dat zelf prettig vindt. Wij betalen geen referenten en bieden geen
        kortingen voor cases — een verhaal moet uw eigen reden hebben.
      </p>
      <a href="mailto:cases@coheza.nl" class="mt-4 inline-block text-sm font-medium text-sindzo-700 no-underline hover:underline">
        cases@coheza.nl →
      </a>
    </div>
  </section>
</Base>
