---
const links = [
  { label: 'Oplossing', href: '/oplossing' },
  { label: 'Voor wie', href: '#voor-wie' },
  { label: 'Integraties', href: '/integraties' },
  { label: 'Trust Centre', href: '/trust' },
  { label: 'Prijzen', href: '/prijzen' },
];
---
<header class="sticky top-0 z-40 border-b border-ink-100 bg-white/85 backdrop-blur supports-[backdrop-filter]:bg-white/70">
  <div class="container-prose flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2 no-underline" aria-label="Sindzo — terug naar home">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-gradient-to-br from-sindzo-700 to-accent-500 text-white"><svg viewBox="0 0 24 24" class="h-[18px] w-[18px]" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-4.5-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 11c0 5.5-7 10-7 10z"/><path d="M9.5 12h1.6l1-2 1.2 3 .9-1.5h1.8"/></svg></span>
      <span class="font-display text-lg font-semibold tracking-tightish text-ink-900">Sindzo</span>
    </a>
    <nav class="hidden md:flex items-center gap-7 text-sm text-ink-700">
      {links.map((l) => (
        <a href={l.href} class="no-underline hover:text-sindzo-700 transition">{l.label}</a>
      ))}
    </nav>
    <div class="flex items-center gap-3">
      <a href="https://app.sindzo.nl/login" class="hidden sm:inline text-sm text-ink-700 hover:text-sindzo-700 no-underline">Inloggen</a>
      <a href="/demo" class="btn-primary no-underline">Demo aanvragen</a>
    </div>
  </div>
</header>
