---
import Base from '../layouts/Base.astro';

// Custom 404. .htaccess (Apache) en Cloudflare Pages serveren dit
// automatisch als dist/404.html als een route niet matched.
// Astro genereert deze pagina als plain HTML; geen server-side logic.
---
<Base
  title="Pagina niet gevonden (404) — Sindzo"
  description="Deze pagina bestaat niet of is verplaatst. Hieronder de meest gezochte ingangen."
>
  <section class="container-prose py-20 sm:py-28">
    <div class="max-w-2xl">
      <span class="eyebrow">Foutcode 404</span>
      <h1 class="mt-3 font-display text-4xl font-bold leading-tight tracking-tightish text-ink-900 sm:text-5xl md:text-6xl">
        Deze pagina bestaat <em class="italic text-accent-600">niet meer</em>.
      </h1>
      <p class="mt-5 text-lg text-ink-700">
        Het kan dat een link verouderd is, dat we de pagina hebben verplaatst, of dat er een typo in de URL zit.
        Probeer een van onderstaande ingangen, of <a href="/contact" class="text-sindzo-700 hover:underline">stuur ons een bericht</a>
        als u op zoek bent naar iets specifieks.
      </p>

      <div class="mt-10 flex flex-wrap gap-3">
        <a href="/" class="btn-primary no-underline">Naar de homepage</a>
        <a href="/oplossing" class="btn-secondary no-underline">Bekijk de oplossing</a>
      </div>
    </div>

    <div class="mt-16 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {[
        { title: 'Oplossing', body: 'Modulekaart met live/wip-stoplichten.', href: '/oplossing' },
        { title: 'Voor wie', body: 'VVT, GHZ, GGZ — segmentpagina\'s.', href: '/voor' },
        { title: 'Integraties', body: 'FHIR, MedMij, Wegiz, LSP en meer.', href: '/integraties' },
        { title: 'Trust Centre', body: 'Eerlijke compliance-status, geen NDA nodig.', href: '/trust' },
        { title: 'Prijzen', body: 'Vier tiers, transparante plan-matrix.', href: '/prijzen' },
        { title: 'Demo aanvragen', body: 'Reactie binnen 1 werkdag, geen verkoopdruk.', href: '/demo' },
      ].map((card) => (
        <a href={card.href} class="rounded-xl border border-ink-100 bg-white p-5 no-underline transition hover:border-sindzo-300 hover:shadow-sm">
          <h2 class="font-display text-base font-semibold text-ink-900">{card.title}</h2>
          <p class="mt-2 text-sm text-ink-700 leading-snug">{card.body}</p>
          <span class="mt-3 inline-block text-xs font-medium text-sindzo-700">Open →</span>
        </a>
      ))}
    </div>
  </section>
</Base>
