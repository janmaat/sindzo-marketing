---
import Base from './Base.astro';

// Gedeeld layout voor legal-pagina's (privacy, voorwaarden, cookies).
// TOC links worden afgeleid uit de h2-elementen die via <slot/> komen —
// niet via runtime parsing maar via een sections-prop zodat we statisch
// renderen en geen JS nodig hebben.

interface Section { id: string; title: string; }

interface Props {
  title: string;
  description?: string;
  eyebrow: string;
  lastUpdated: string;  // ISO date string
  sections: Section[];
  draft?: boolean;
}

const { title, description, eyebrow, lastUpdated, sections, draft = true } = Astro.props;
const dateNl = new Date(lastUpdated).toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' });
---
<Base title={title} description={description}>
  <section class="border-b border-ink-100 bg-gradient-to-b from-sindzo-50 to-white">
    <div class="container-prose py-14 sm:py-20">
      <span class="text-xs font-semibold uppercase tracking-wider text-sindzo-700">{eyebrow}</span>
      <h1 class="mt-3 font-display text-4xl font-bold leading-tight tracking-tightish text-ink-900 sm:text-5xl max-w-3xl">{title}</h1>
      <p class="mt-4 text-sm text-ink-500">Laatst gewijzigd: {dateNl}</p>
      {draft && (
        <div class="mt-6 max-w-2xl rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
          <strong>Concept-versie.</strong> Deze tekst wordt herzien door onze juridisch adviseur vóór commerciële go-live.
          Voor productie-zekerheid: laat uw eigen jurist of FG meekijken.
        </div>
      )}
    </div>
  </section>

  <section class="container-prose py-12">
    <div class="grid gap-12 lg:grid-cols-[220px_1fr]">
      <aside class="lg:sticky lg:top-24 lg:self-start">
        <nav aria-label="Inhoudsopgave">
          <h2 class="text-xs font-semibold uppercase tracking-wider text-ink-500">Inhoud</h2>
          <ol class="mt-4 space-y-2 text-sm">
            {sections.map((s, i) => (
              <li>
                <a href={`#${s.id}`} class="text-ink-700 no-underline hover:text-sindzo-700">
                  <span class="text-ink-500">{i + 1}.</span> {s.title}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      </aside>
      <article class="prose-content max-w-prose text-ink-700 leading-relaxed">
        <slot />
      </article>
    </div>
  </section>
</Base>

<style>
  .prose-content :global(h2) {
    @apply mt-12 first:mt-0 font-display text-2xl font-bold text-ink-900 tracking-tightish;
  }
  .prose-content :global(h3) {
    @apply mt-8 font-display text-lg font-semibold text-ink-900;
  }
  .prose-content :global(p) {
    @apply mt-4 text-base;
  }
  .prose-content :global(ul) {
    @apply mt-4 list-disc space-y-2 pl-6 text-base;
  }
  .prose-content :global(ol) {
    @apply mt-4 list-decimal space-y-2 pl-6 text-base;
  }
  .prose-content :global(a) {
    @apply text-sindzo-700 underline;
  }
  .prose-content :global(strong) {
    @apply font-semibold text-ink-900;
  }
  .prose-content :global(table) {
    @apply mt-6 w-full border-collapse text-sm;
  }
  .prose-content :global(th),
  .prose-content :global(td) {
    @apply border-b border-ink-100 py-2 pr-4 text-left align-top;
  }
  .prose-content :global(th) {
    @apply font-semibold text-ink-900;
  }
</style>
