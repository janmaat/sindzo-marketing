---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Cta from '../components/Cta.astro';

const phases = [
  {
    week: 'Week 1–2',
    title: 'Verkenning',
    deliverables: [
      'Workshop zorgproces (3 typische werkstromen)',
      'ICT-landschap-scan (huidige systemen, koppelingen)',
      'Stakeholder-map: bestuur, I&A, FG, eindgebruikers',
      'Migratie-haalbaarheid (huidig ECD/HIS)',
    ],
  },
  {
    week: 'Week 3–4',
    title: 'Inrichting',
    deliverables: [
      'Tenant-aanmaak + identiteits-koppeling (SSO)',
      'Functierollen-mapping (Identity-module)',
      'Modules activeren per plan',
      'Branding + organisatieprofiel',
    ],
  },
  {
    week: 'Week 5–8',
    title: 'Migratie & training',
    deliverables: [
      'Data-import (cliënten, contracten, openstaande zorgplannen)',
      'Super-user-training (5–10 sleutelfiguren)',
      'E-learning voor eindgebruikers (self-paced)',
      'Schaduw-periode op pilot-team',
    ],
  },
  {
    week: 'Week 9–10',
    title: 'Pilot live',
    deliverables: [
      'Pilot-team live (1 locatie of 1 wijk)',
      'Daily standup eerste week',
      'Issue-triage <24u',
      'Feedback-loop naar productteam',
    ],
  },
  {
    week: 'Week 11–13',
    title: 'Brede uitrol',
    deliverables: [
      'Fasering per locatie/team',
      'On-site begeleiding bij elke go-live',
      'Tweede ring super-users opgeleid',
      'Operationeel ritme (changelog, releases)',
    ],
  },
  {
    week: 'Week 14+',
    title: 'Optimalisatie',
    deliverables: [
      'Eerste KPI-review (time-to-rapport, regeldruk-index)',
      'Aanvullende modules activeren',
      'Custom-koppelingen op verzoek',
      'Jaarlijkse architecture-review (Enterprise)',
    ],
  },
];

const principles = [
  {
    title: 'Multidisciplinaire projectgroep',
    body: 'Bestuur, I&A, zorginhoud, FG én eindgebruikers vanaf dag 1. Sindzo wijst een NL-implementatieleider toe, geen ticketsysteem.',
  },
  {
    title: 'Procesfit boven feature-fit',
    body: 'Wij toetsen niet of u 100% van uw eisen kunt aanvinken, maar of úw werkstromen erin werken. Aanpassingen vóór go-live, niet erna.',
  },
  {
    title: 'Super-users als versneller',
    body: '5–10 sleutelmedewerkers krijgen verdiepende training en blijven 6 maanden eerste-lijn-vraagbaak — bewezen patroon in NL implementaties.',
  },
  {
    title: 'Gefaseerd, geen big-bang',
    body: 'Pilot op 1 locatie, dan ring uitbreiden. Liever 3 weken later breed-live met goede adoptie dan dag-1 met chaos.',
  },
];
---
<Base
  title="Implementatie-aanpak | Sindzo"
  description="14-weken-uitrol met multidisciplinaire projectgroep, super-user-aanpak en gefaseerde livegang. Geen big-bang, geen ticketsysteem."
>
  <PageHero
    eyebrow="Implementatie"
    title="Onze richtinggevende aanpak — van kick-off naar productie."
    subtitle="Vervangingstrajecten falen zelden op de software en vaak op het verandertraject. Hieronder onze beoogde implementatie-aanpak — multidisciplinaire projectgroep, super-user-versnellers, gefaseerde livegang. Werkelijke duur en fasering stemmen we per klant af voordat er getekend wordt."
  >
    <div slot="actions" class="flex flex-wrap gap-3">
      <a href="/demo" class="btn-primary no-underline">Demo aanvragen</a>
      <a href="/procurement" class="btn-secondary no-underline">Procurement-pack</a>
    </div>
  </PageHero>

  <section class="container-prose py-16">
    <h2 class="font-display text-2xl font-bold text-ink-900 sm:text-3xl">Vier principes</h2>
    <p class="mt-3 max-w-2xl text-ink-700">
      Gebaseerd op publieke implementatie-cases en sectorbronnen (NVZ-VIPP, ActiZ). Wij
      passen de aanpak per klant aan op uw werkelijke situatie — geen one-size-fits-all.
    </p>
    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {principles.map((p) => (
        <div class="rounded-xl border border-ink-100 bg-white p-6">
          <h3 class="font-display text-lg font-semibold text-ink-900">{p.title}</h3>
          <p class="mt-2 text-sm text-ink-700 leading-relaxed">{p.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="border-t border-ink-100 bg-ink-100/40 py-16">
    <div class="container-prose">
      <h2 class="font-display text-2xl font-bold text-ink-900 sm:text-3xl">Indicatieve tijdlijn — kick-off tot productie</h2>
      <p class="mt-3 max-w-2xl text-ink-700">
        De fases hieronder zijn ons referentie-model. Werkelijke duur hangt af van uw schaal,
        migratiecomplexiteit en beschikbaarheid van uw projectgroep — we stellen het samen vast
        vóór tekening.
      </p>
      <ol class="mt-10 space-y-4">
        {phases.map((p, i) => (
          <li class="rounded-xl border border-ink-100 bg-white p-6">
            <div class="grid gap-4 sm:grid-cols-[120px_180px_1fr] sm:items-start">
              <div>
                <div class="font-display text-xs font-semibold uppercase tracking-wider text-sindzo-700">Fase {i + 1}</div>
                <div class="text-sm font-semibold text-ink-900">{p.week}</div>
              </div>
              <div class="font-display text-lg font-semibold text-ink-900">{p.title}</div>
              <ul class="space-y-1.5 text-sm text-ink-700">
                {p.deliverables.map((d) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-1.5 inline-block h-1.5 w-1.5 rounded-full bg-sindzo-500"></span>
                    <span>{d}</span>
                  </li>
                ))}
              </ul>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="container-prose py-16">
    <div class="grid gap-10 lg:grid-cols-2">
      <div class="rounded-2xl border border-ink-100 bg-white p-8">
        <h3 class="font-display text-xl font-semibold text-ink-900">Wat wij van u nodig hebben</h3>
        <ul class="mt-4 space-y-2.5 text-sm text-ink-700">
          <li>1 projectleider met 0,4 fte voor de duur</li>
          <li>5–10 super-users uit zorg, planning, declaratie</li>
          <li>Bestuurlijke besluitvaardigheid bij scope-keuzes</li>
          <li>Toegang tot huidige ECD/HIS voor data-export</li>
          <li>FG-akkoord op DPA en DPIA-template</li>
        </ul>
      </div>
      <div class="rounded-2xl border border-ink-100 bg-white p-8">
        <h3 class="font-display text-xl font-semibold text-ink-900">Wat wij leveren</h3>
        <ul class="mt-4 space-y-2.5 text-sm text-ink-700">
          <li>NL-implementatieleider als vast aanspreekpunt</li>
          <li>Migratie-import en validatie-rapport</li>
          <li>Training voor super-users + e-learning eindgebruikers</li>
          <li>On-site begeleiding bij elke go-live</li>
          <li>Issue-triage &lt;24u eerste 3 maanden</li>
          <li>Procurement-pack: PVE-template, DPA, SLA, architectuurplaat</li>
        </ul>
      </div>
    </div>
  </section>

  <Cta
    title="Wilt u de implementatie-aanpak in detail bespreken?"
    subtitle="Plan een verkenning. Wij sturen vooraf onze procurement-pack zodat uw inkoop-, FG- en I&A-team alvast kan lezen."
  />
</Base>
