---
const year = new Date().getFullYear();
const columns = [
  {
    title: 'Product',
    links: [
      { label: 'Oplossing', href: '/oplossing' },
      { label: 'Integraties', href: '/integraties' },
      { label: 'Prijzen', href: '/prijzen' },
      { label: 'Implementatie', href: '/implementatie' },
      { label: 'Vergelijking', href: '/vergelijking' },
    ],
  },
  {
    title: 'Voor wie',
    links: [
      { label: 'VVT', href: '/voor/vvt' },
      { label: 'Gehandicaptenzorg', href: '/voor/ghz' },
      { label: 'GGZ', href: '/voor/ggz' },
      { label: 'Huisartsen', href: '/voor/huisartsen' },
    ],
  },
  {
    title: 'Vertrouwen',
    links: [
      { label: 'Trust Centre', href: '/trust' },
      { label: 'Status', href: 'https://status.coheza.nl' },
      { label: 'Privacy', href: '/privacy' },
      { label: 'Architectuur-besluiten', href: '/adr' },
    ],
  },
  {
    title: 'Bedrijf',
    links: [
      { label: 'Over Coheza', href: '/over' },
      { label: 'Kennisbank', href: '/kennisbank' },
      { label: 'Contact', href: '/contact' },
      { label: 'Demo aanvragen', href: '/demo' },
    ],
  },
];
---
<footer class="mt-24 border-t border-ink-100 bg-ink-100/30">
  <div class="container-prose py-14">
    <div class="grid grid-cols-2 gap-10 md:grid-cols-5">
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2">
          <img src="/logo/coheza-logo.svg" alt="Coheza" class="h-8 w-auto" width="120" height="32" />
        </div>
        <p class="mt-3 text-sm text-ink-500 max-w-xs">
          Eén zorgsuite voor de Nederlandse zorgpraktijk — bewust open, aantoonbaar veilig.
        </p>
        <p class="mt-3 text-xs text-ink-500">
          Gevestigd in Almelo, Nederland.
        </p>
        <p class="mt-4 text-sm">
          <a href="tel:+31611746283" class="inline-flex items-center gap-1.5 text-ink-700 no-underline hover:text-sindzo-700">
            <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
            </svg>
            <span class="font-medium">+31 6 11 74 62 83</span>
          </a>
        </p>
        <p class="mt-1.5 text-sm">
          <a href="mailto:hello@coheza.nl" class="inline-flex items-center gap-1.5 text-ink-700 no-underline hover:text-sindzo-700">
            <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            <span class="font-medium">hello@coheza.nl</span>
          </a>
        </p>
      </div>
      {columns.map((col) => (
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-500">{col.title}</h4>
          <ul class="mt-4 space-y-2 text-sm">
            {col.links.map((l) => (
              <li>
                <a href={l.href} {...(l.external ? { target: '_blank', rel: 'noopener' } : {})} class="text-ink-700 no-underline hover:text-sindzo-700">{l.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="mt-12 flex flex-col gap-2 border-t border-ink-100 pt-6 text-xs text-ink-500 sm:flex-row sm:items-center sm:justify-between">
      <span>© {year} Coheza · gevestigd in Nederland.</span>
      <div class="flex gap-5">
        <a href="/privacy" class="no-underline hover:text-sindzo-700">Privacyverklaring</a>
        <a href="/voorwaarden" class="no-underline hover:text-sindzo-700">Voorwaarden</a>
        <a href="/cookies" class="no-underline hover:text-sindzo-700">Cookies</a>
      </div>
    </div>
  </div>
</footer>
