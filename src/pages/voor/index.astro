---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import Cta from '../../components/Cta.astro';

// Eigen indexpagina voor "Voor wie" — voorkomt dat de nav-link op subpagina's
// terugspringt naar #voor-wie op de homepage (gebroken navigatiepatroon).

const segments = [
  {
    label: 'VVT',
    title: 'Verpleging, verzorging & thuiszorg',
    pitch: 'Eén werkproces over intra- en extramuraal. Planning + ECD + eOverdracht, gebouwd voor arbeidskrapte.',
    href: '/voor/vvt',
    accent: 'from-sindzo-100 to-sindzo-50',
  },
  {
    label: 'GHZ',
    title: 'Gehandicaptenzorg',
    pitch: 'OPP/AVB-ondersteuning, dagbestedinglogistiek, familieportaal — zonder duizend losse formulieren.',
    href: '/voor/ghz',
    accent: 'from-greensoft to-cream',
  },
  {
    label: 'GGZ',
    title: 'Geestelijke gezondheidszorg',
    pitch: 'Blended care, ZPM-declaratie, wachtlijstreductie en e-health-koppelingen in één dossier.',
    href: '/voor/ggz',
    accent: 'from-sindzo-50 to-cream',
  },
];
---
<Base
  title="Voor wie is Sindzo? — VVT, GHZ en GGZ | Sindzo"
  description="Modulair platform voor Nederlandse zorgaanbieders in VVT, gehandicaptenzorg en GGZ. Activeer alleen wat u nodig hebt en groei mee zonder migratie."
>
  <PageHero
    eyebrow="Voor wie"
    title="Voor wie is Sindzo gebouwd?"
    subtitle="Sindzo is een modulaire monolith: u activeert alleen wat u nodig hebt — en groeit mee zonder migratiepijn. Hieronder de segmenten waarvoor het platform productieklaar is."
  >
    <div slot="actions" class="flex flex-wrap gap-3">
      <a href="/oplossing" class="btn-primary no-underline">Bekijk modulekaart</a>
      <a href="/prijzen" class="btn-secondary no-underline">Prijzen</a>
    </div>
  </PageHero>

  <section class="container-prose py-16">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {segments.map((s) => (
        <a href={s.href} class="group relative overflow-hidden rounded-xl border border-ink-300 bg-white p-6 no-underline transition hover:border-sindzo-300 hover:shadow-md">
          <div class={`absolute inset-x-0 top-0 h-24 -z-0 bg-gradient-to-b ${s.accent}`}></div>
          <div class="relative">
            <span class="text-xs font-semibold uppercase tracking-wider text-sindzo-700">{s.label}</span>
            <h3 class="mt-3 font-display text-lg font-semibold text-ink-900">{s.title}</h3>
            <p class="mt-2 text-sm text-ink-700 leading-relaxed">{s.pitch}</p>
            <span class="mt-5 inline-block text-sm font-medium text-sindzo-700 transition group-hover:translate-x-0.5">
              Naar segmentpagina →
            </span>
          </div>
        </a>
      ))}
    </div>

    <p class="mt-8 text-sm text-ink-500 max-w-3xl">
      <strong class="text-ink-700">Eerstelijnszorg (huisartsen)</strong> — in voorbereiding.
      PGO/MedMij-aansluiting en XIS-keurmerkpad lopen, verwachte beschikbaarheid 2027.
      Neem contact op voor de actuele roadmap.
    </p>
  </section>

  <Cta />
</Base>
