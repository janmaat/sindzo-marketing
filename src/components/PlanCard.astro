---
interface Props {
  name: string;
  tagline: string;
  priceFrom?: string;
  priceUnit?: string;
  features: string[];
  cta: { label: string; href: string };
  highlight?: boolean;
}
const {
  name, tagline, priceFrom, priceUnit = 'per medewerker / maand',
  features, cta, highlight = false,
} = Astro.props;

const wrapper = highlight
  ? 'rounded-2xl border-2 border-sindzo-600 bg-white p-8 shadow-lg shadow-sindzo-100 ring-4 ring-sindzo-50'
  : 'rounded-2xl border border-ink-300 bg-white p-8';
---
<article class={`flex flex-col ${wrapper}`}>
  {highlight && (
    <span class="badge mb-2 self-start border-sindzo-300 bg-greensoft text-sindzo-700">
      Meestgekozen
    </span>
  )}
  <h3 class="font-display text-2xl font-bold text-ink-900">{name}</h3>
  <p class="mt-1 text-sm text-ink-700">{tagline}</p>
  <div class="mt-6">
    {priceFrom ? (
      <>
        <div class="flex items-baseline gap-1">
          <span class="text-xs font-medium text-ink-500">vanaf</span>
          <span class="font-display text-3xl font-bold text-ink-900">{priceFrom}</span>
        </div>
        <p class="text-xs text-ink-500">{priceUnit}</p>
      </>
    ) : (
      <p class="font-display text-xl font-semibold text-ink-700">Op aanvraag</p>
    )}
  </div>
  <ul class="mt-6 flex-1 space-y-2 text-sm text-ink-700">
    {features.map((f) => (
      <li class="flex items-start gap-2">
        <span class="mt-1.5 inline-block h-1.5 w-1.5 rounded-full bg-sindzo-500"></span>
        <span>{f}</span>
      </li>
    ))}
  </ul>
  <a
    href={cta.href}
    class={`mt-8 inline-flex items-center justify-center rounded-full px-5 py-2.5 text-sm font-bold no-underline transition ${
      highlight
        ? 'bg-accent-500 text-[#06231f] hover:bg-accent-600'
        : 'border border-ink-300 bg-white font-semibold text-sindzo-900 hover:bg-sand'
    }`}
  >
    {cta.label}
  </a>
</article>
