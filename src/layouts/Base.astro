---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
}

const {
  title,
  description = 'Sindzo — één zorgsuite voor dossier, planning, declaratie en kwaliteit. Bewust open, aantoonbaar veilig, gebouwd voor de Nederlandse zorgpraktijk.',
  canonical,
  image = '/og.png',
} = Astro.props;

const url = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Sindzo',
  url: Astro.site?.toString() ?? 'https://sindzo.nl',
  logo: new URL('/favicon.svg', Astro.site).toString(),
  description: 'Eén zorgsuite voor de Nederlandse zorgpraktijk — dossier, planning, declaratie en kwaliteit in één modulair platform.',
  parentOrganization: { '@type': 'Organization', name: 'Maat Holding B.V.' },
  areaServed: 'NL',
};
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:locale" content="nl_NL" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(orgLd)} />
    {/* Fonts (Fraunces + Mulish) worden self-hosted geladen via src/styles/fonts.css. */}
    {/*
      Plausible Analytics — cookie-loos, EU-gehost (geen GA, geen tracker-popups).
      Alleen in productie laden zodat dev-traffic geen statistiek vervuilt.
    */}
    {import.meta.env.PROD && (
      <script defer data-domain="sindzo.nl" src="https://plausible.io/js/script.outbound-links.js"></script>
      <script is:inline set:html={`window.plausible = window.plausible || function() { (window.plausible.q = window.plausible.q || []).push(arguments) }`} />
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
