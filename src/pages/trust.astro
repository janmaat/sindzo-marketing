---
import Base from '../layouts/Base.astro';
import { NIS2CARE_LIVE, NIS2CARE_URL } from '../config/features';

// Trust Centre — kerncompetentie t.o.v. concurrenten die deze info pas in
// tender-fase delen. Eerlijke status, niet marketing-spraak. Iedere claim
// linkt naar onderbouwing (zodra documenten publiek beschikbaar zijn).
//
// Status-conventie:
//   live    — aantoonbaar nu, document beschikbaar
//   wip     — in afronding met concrete tijdslijn
//   roadmap — gepland maar nog niet gestart

const pillars = [
  {
    key: 'security',
    title: 'Informatiebeveiliging',
    intro: 'NEN 7510-werkdocument is leidend. Pen-tests jaarlijks via NL-CERT-aangesloten partij.',
    items: [
      { label: 'NEN 7510:2024', status: 'wip', note: 'Control-suite geïmplementeerd met baseline-assessments, externe audit Q4 2026', doc: '#nen7510' },
      { label: 'NEN 7512 (uitwisseling)', status: 'wip', note: 'Toegepast op FHIR-/LSP-koppelingen', doc: '#nen7512' },
      { label: 'NEN 7513 (logging)', status: 'live', note: 'Onveranderbare auditlog, 7 jaar bewaartermijn', doc: '#nen7513' },
      { label: 'ISO 27001', status: 'roadmap', note: 'Audit gepland 2027', doc: '#iso27001' },
      { label: 'Pentest jaarlijks', status: 'live', note: 'Grey-box, NL-CERT-aangesloten partij — managementsamenvatting publiek, volledig rapport onder NDA', doc: '#pentest' },
      { label: 'Encryptie at-rest', status: 'live', note: 'AES-256-GCM per tenant-sleutel', doc: '#encryption' },
    ],
  },
  {
    key: 'privacy',
    title: 'Privacy & gegevensbescherming',
    intro: 'AVG-conform met expliciete verwerkers-rolverdeling. PII (BSN, AGB) altijd encrypted.',
    items: [
      { label: 'AVG / GDPR', status: 'live', note: 'Standaard-DPA volgens AP-model, NL/EN beschikbaar', doc: '#dpa' },
      { label: 'Verwerkersovereenkomst', status: 'live', note: 'Standaard-DPA op aanvraag (~1 werkdag), geen NDA nodig', doc: '/procurement' },
      { label: 'Subverwerkers-overzicht', status: 'live', note: 'Volledig overzicht beschikbaar, alle in EER', doc: '#subverwerkers' },
      { label: 'DPIA-template', status: 'live', note: 'Voor zorgaanbieder eigen DPIA — op aanvraag', doc: '/procurement' },
      { label: 'BSN-encryptie', status: 'live', note: 'AES-256-GCM met HKDF envelope per tenant, kwartaal-rotatie van masters (operationeel proces)', doc: '#bsn' },
      { label: 'Recht op vergetelheid', status: 'live', note: 'Pseudonimisering + audit-trail', doc: '#vergetelheid' },
    ],
  },
  {
    key: 'interop',
    title: 'Interoperabiliteit & openheid',
    intro: 'Open API\'s, FHIR-endpoints en publieke koppeldocumentatie. Geen vendor lock-in.',
    items: [
      { label: 'FHIR R4', status: 'wip', note: '8 Zibs intern actief (Patient, Encounter, Observation, MedicationStatement, Condition, AllergyIntolerance, RelatedPerson, CarePlan); publieke REST API Q4 2026', doc: '/api' },
      { label: 'MedMij', status: 'wip', note: 'Interne brug gereed; DVZA-registratie + PKIoverheid-cert in voorbereiding (Q4 2026)', doc: '#medmij' },
      { label: 'Wegiz / eOverdracht', status: 'wip', note: 'BgZ 8/15 Zibs actief; Nuts-aansluiting Q4 2026', doc: '#wegiz' },
      { label: 'LSP', status: 'wip', note: 'VZVZ-aansluittraject + UZI-certificaten — gateway ingericht, ketentest in afronding', doc: '#lsp' },
      { label: 'Open API', status: 'wip', note: 'OpenAPI 3.1-spec compleet, publieke sandbox in afronding Q3 2026 — toegang nu op aanvraag', doc: '/api' },
      { label: 'Data-export', status: 'live', note: 'Volledige export in JSON/CSV op verzoek', doc: '#export' },
    ],
  },
  {
    key: 'operations',
    title: 'Operationele continuïteit',
    intro: 'NL-hosting, transparante uptime, publieke status-page en herstelplan getest.',
    items: [
      { label: 'NL-hosting', status: 'live', note: 'Azure West-Europe + backup NL', doc: '#hosting' },
      { label: 'Uptime SLA', status: 'live', note: '99,9% productie, gemeten extern', doc: 'https://status.sindzo.nl' },
      { label: 'Statuspagina publiek', status: 'live', note: 'Incidenten + onderhoudsvensters', doc: 'https://status.sindzo.nl' },
      { label: 'BCM-test', status: 'live', note: 'Jaarlijkse restore-oefening', doc: '#bcm' },
      { label: 'RPO / RTO', status: 'live', note: 'RPO 1 uur, RTO 4 uur', doc: '#rto' },
      { label: 'Exit-procedure', status: 'live', note: 'Contractueel vastgelegd in MSA', doc: '#exit' },
    ],
  },
  {
    key: 'regulatory',
    title: 'Wettelijke kaders & sectorregels',
    intro: 'Wkkgz, Wzd, Wtza, Wtta en de Cyberbeveiligingswet — actief gevolgd, niet afgewacht.',
    items: [
      { label: 'Cbw (NIS2)', status: 'wip', note: 'NIS2-incidentmodule (24/72/720u SLA-tracking) ingebouwd in Sindzo; ook los beschikbaar als Nis2Care voor non-Sindzo-klanten. Klaar voor 1 juli 2026.', doc: NIS2CARE_LIVE ? NIS2CARE_URL : '#cbw' },
      { label: 'Wkkgz-klachtenregeling', status: 'live', note: 'Module + workflow standaard', doc: '#wkkgz' },
      { label: 'Wzd-stappenplan', status: 'live', note: 'Halfjaarlijkse IGJ-XML', doc: '#wzd' },
      { label: 'Wtza-jaarverantwoording', status: 'live', note: 'Wizard voor deadline 31 mei', doc: '#wtza' },
      { label: 'Wtta-uitlenersregister', status: 'wip', note: 'Module beschikbaar 1 sep 2026 — 4 maanden vóór wettelijke deadline', doc: '#wtta' },
      { label: 'AI Act high-risk', status: 'wip', note: 'Classificatie + register beschikbaar 1 sep 2026 — ruim vóór 2 dec 2027', doc: '#ai-act' },
    ],
  },
];

const dot = (s: string) =>
  s === 'live' ? 'bg-green-500' : s === 'wip' ? 'bg-amber-500' : 'bg-ink-300';

const statusLabel = (s: string) =>
  s === 'live' ? 'Aantoonbaar' : s === 'wip' ? 'In afronding' : 'Op roadmap';
---
<Base
  image="/og/trust.png"
  title="Trust Centre — Sindzo"
  description="Eerlijke status van onze compliance, security, privacy en interoperabiliteit. Geen NDA nodig om dit te lezen."
>
  <section class="border-b border-ink-300 bg-gradient-to-b from-sindzo-50 to-cream">
    <div class="container-prose py-16 sm:py-20">
      <span class="badge mb-5">Trust Centre · laatst herzien {new Date().toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
      <h1 class="font-display text-4xl font-bold tracking-tightish text-ink-900 sm:text-5xl max-w-3xl">
        Compliance op tafel, niet in een PDF achter een NDA.
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-ink-700">
        Inkoop, FG, CISO en bestuur kunnen Sindzo beoordelen vóór er een gesprek nodig is.
        Elk item hieronder heeft een eerlijke status — groen, geel of grijs — met onderbouwing.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-4 text-sm">
        <a href="/procurement" class="btn-primary no-underline">Naar Procurement Centre</a>
        <a href="mailto:trust@sindzo.nl?subject=Security-pack%20%2B%20DPA%20aanvragen" class="btn-secondary no-underline">Vraag security-pack + DPA</a>
        <a href="https://status.sindzo.nl" class="text-sindzo-700 font-medium no-underline hover:underline">Live status →</a>
      </div>
      <p class="mt-6 text-xs text-ink-500">
        <span class="status-dot bg-green-500"></span> aantoonbaar nu
        <span class="status-dot bg-amber-500 ml-4"></span> in afronding (met datum)
        <span class="status-dot bg-ink-300 ml-4"></span> op roadmap
      </p>
    </div>
  </section>

  {pillars.map((pillar) => (
    <section id={pillar.key} class="container-prose py-14 border-b border-ink-100 last:border-0">
      <div class="grid gap-10 md:grid-cols-[260px_1fr]">
        <div>
          <h2 class="font-display text-2xl font-bold text-ink-900">{pillar.title}</h2>
          <p class="mt-3 text-sm text-ink-700 leading-relaxed">{pillar.intro}</p>
        </div>
        <ul class="grid gap-3 sm:grid-cols-2">
          {pillar.items.map((item) => (
            <li class="rounded-lg border border-ink-100 bg-white p-4">
              <div class="flex items-start gap-3">
                <span class={`status-dot mt-1.5 shrink-0 ${dot(item.status)}`}></span>
                <div class="flex-1">
                  <div class="flex items-center justify-between gap-3">
                    <span class="font-semibold text-ink-900 text-sm">{item.label}</span>
                    <span class="text-[10px] uppercase tracking-wider text-ink-500">{statusLabel(item.status)}</span>
                  </div>
                  <p class="mt-1 text-xs text-ink-500 leading-snug">{item.note}</p>
                  {item.doc?.startsWith('http') ? (
                    <a href={item.doc} target="_blank" rel="noopener" class="mt-2 inline-block text-xs font-medium text-sindzo-700 no-underline hover:underline">
                      Onderbouwing ↗
                    </a>
                  ) : (
                    <a href={item.doc} class="mt-2 inline-block text-xs font-medium text-sindzo-700 no-underline hover:underline">
                      Onderbouwing →
                    </a>
                  )}
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ))}

  <section class="container-prose py-16 border-b border-ink-100">
    <div class="rounded-2xl border border-amber-200 bg-amber-50/60 p-8 sm:p-12">
      <div class="max-w-3xl">
        <h2 class="font-display text-2xl font-bold text-ink-900">De vraag die inkopers stellen: "Wat als de bouwer wegvalt?"</h2>
        <p class="mt-3 text-ink-700">
          Sindzo wordt gebouwd door één hoofd­architect met selecte partners. We benoemen dit actief omdat u er toch naar gaat vragen:
        </p>
        <ul class="mt-5 space-y-3 text-sm text-ink-700">
          <li class="flex gap-3"><span class="mt-0.5 inline-block h-2 w-2 shrink-0 rounded-full bg-amber-500"></span><span><strong>Broncode-escrow</strong> — overeenkomst met SRK-escrow­agent in voorbereiding (Q3 2026). Activerings­drempel: drie aaneengesloten maanden geen oplevering.</span></li>
          <li class="flex gap-3"><span class="mt-0.5 inline-block h-2 w-2 shrink-0 rounded-full bg-green-500"></span><span><strong>Technische documentatie</strong> — volledig, actueel, in de repo. Een gekwalificeerde .NET-ontwikkelaar kan het systeem zelfstandig overnemen en uitbreiden.</span></li>
          <li class="flex gap-3"><span class="mt-0.5 inline-block h-2 w-2 shrink-0 rounded-full bg-amber-500"></span><span><strong>Ontwikkelaarspartnerschap</strong> — afspraken met twee NL-gebaseerde .NET-zorgpartners in voorbereiding. Continuïteits­plan inclusief SLA beschikbaar na ondertekening MSA.</span></li>
          <li class="flex gap-3"><span class="mt-0.5 inline-block h-2 w-2 shrink-0 rounded-full bg-green-500"></span><span><strong>Data-portabiliteit</strong> — volledige export in JSON/CSV/FHIR R4 op elk moment, contractueel vastgelegd. U bent nooit afhankelijk van onze inzet om uw eigen data te krijgen.</span></li>
          <li class="flex gap-3"><span class="mt-0.5 inline-block h-2 w-2 shrink-0 rounded-full bg-green-500"></span><span><strong>Directe lijn als kracht</strong> — kleinere leverancier betekent ook: geen supportdesk-bureaucratie, geen tickets die kwartalen reizen. U spreekt rechtstreeks met de bouwers; fixes in dagen, niet in releases per jaar.</span></li>
        </ul>
        <p class="mt-5 text-sm text-ink-500">Founding partners ontvangen aanvullende garanties en zijn mede-eigenaar van de roadmap. Vraag de aanvullende continuïteitsverklaring op via <a href="mailto:trust@sindzo.nl" class="text-sindzo-700 hover:underline no-underline">trust@sindzo.nl</a>.</p>
      </div>
    </div>
  </section>

  <section class="container-prose py-16">
    <div class="rounded-2xl border border-ink-200 bg-ink-100/50 p-8 sm:p-12">
      <h2 class="font-display text-2xl font-bold text-ink-900">Iets niet duidelijk?</h2>
      <p class="mt-3 max-w-2xl text-ink-700">
        Stuur een vraag rechtstreeks naar onze FG of security-lead. Reactie binnen 1 werkdag.
        Voor due-diligence-vragen accepteren we standaard vragenlijsten (CAIQ, SIG, BSI C5).
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="mailto:trust@sindzo.nl" class="btn-primary no-underline">trust@sindzo.nl</a>
        <a href="/contact" class="btn-secondary no-underline">Stuur vragenlijst</a>
      </div>
    </div>
  </section>
</Base>
