---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import ModuleCard from '../components/ModuleCard.astro';
import ProductMockups from '../components/ProductMockups.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import Cta from '../components/Cta.astro';

// Modulekaart — gegroepeerd zoals de Blazor-app ook gegroepeerd is
// (ECD/Declaratie/Planning/Kwaliteit/...). Statussen reflecteren
// werkelijke staat in de codebase.

interface ModuleEntry {
  icon: string;
  title: string;
  body: string;
  features?: string[];
  status?: 'live' | 'wip' | 'roadmap';
}

interface ModuleGroup {
  group: string;
  intro: string;
  modules: ModuleEntry[];
}

const groups: ModuleGroup[] = [
  {
    group: 'ECD — cliëntdossier',
    intro: 'Eén dossier dat met de cliënt meereist door intake, behandeling en overdracht.',
    modules: [
      { icon: '📋', title: 'Cliëntdossier (Core)', body: 'BSN-encrypted, multi-tenant, met archiefbeleid en field-level audit.',
        features: ['Episode of Care', 'Anamnese + Allergieën', 'CIZ/Wmo-indicaties', 'BgZ-conform'], status: 'live' },
      { icon: '📝', title: 'SOEP-rapportage', body: 'AI-pre-fill, spraakinvoer, automatische samenvatting en correcties-trail.',
        features: ['Spraak-naar-tekst', 'AI-pre-fill', 'Verbeter-trail', 'Pin & redact'], status: 'live' },
      { icon: '🎯', title: 'Omaha Zorgplan', body: 'Volledig Omaha-systeem met problemen, doelen, interventies en versie-snapshots. Plus: cliëntformulering + mantelzorgperspectief naast professionele formulering, SMART-doelen met streefdatum, en risicoprofielen-engine (val/decubitus/ondervoeding/delier) die automatisch op metingen draait.', status: 'live' },
      { icon: '🧠', title: 'Vragenlijsten-engine', body: 'PREM/MIC/BEM-engine met flexibele schalen en geautomatiseerde verspreiding.', status: 'live' },
      { icon: '👥', title: 'Groepszorg', body: 'Dagbesteding en dagbehandeling — activiteiten, aanwezigheid, foto\'s en rapportages.', status: 'live' },
      { icon: '🤝', title: 'MDO + cliëntlogistiek', body: 'Multidisciplinair overleg, agenda-templates, actiepunten en intake-flow.', status: 'live' },
      { icon: '🩹', title: 'Wondregistratie', body: 'Wondclassificatie (RYB/EPUAP), metingen, fotorapportage en wondgeschiedenis per cliënt.', status: 'live' },
      { icon: '📑', title: 'Anamnese & InterRAI', body: 'Gestructureerde intake-anamnese met CIZ-domeinen en InterRAI-assessments met CAP-rapportage.', status: 'live' },
      { icon: '✅', title: 'Interventietaken', body: 'Plan-gedreven uitvoertaken die automatisch volgen uit actieve zorgplaninterventies.', status: 'live' },
    ],
  },
  {
    group: 'Declaratie & financiering',
    intro: 'Heel het declaratie-spectrum — Wmo, Jw, Wlz, Zvw — in één engine.',
    modules: [
      { icon: '🏷️', title: 'AGB-registraties', body: 'AGB-aanvraag, validatie, sync en organisatie-koppeling.', status: 'live' },
      { icon: '✅', title: 'COV-check', body: 'Real-time controle op verzekering, batch- of single-flow.', status: 'live' },
      { icon: '🏛️', title: 'iWmo / iJw', body: 'Gemeente-productcodes, message-flow, retourcodes, toewijzingen.', status: 'live' },
      { icon: '🩺', title: 'iWlz + CAK', body: 'Wlz-berichten en CAK-aanleveringen met retour-mutaties.', status: 'live' },
      { icon: '📊', title: 'Productie & Budget', body: 'Per cliënt productie, financierings-mix, budgetreserveringen + alerts.', status: 'live' },
      { icon: '💶', title: 'Facturatie + PGB', body: 'Facturen, betalingen, sjablonen en PGB-afrekeningen.', status: 'live' },
      { icon: '🧠', title: 'ZPM-declaratie (GGZ)', body: 'Native registratie van zorgprestaties volgens het Zorgprestatiemodel — validatie aan de bron, niet bij de declaratie-knop.', status: 'live' },
      { icon: '💼', title: 'Cliëntkas + Bewindvoering', body: 'Zakgeld- en kassabeheer per cliënt, uitgavenregistratie en rapportage voor bewindvoerders.', status: 'live' },
      { icon: '🚑', title: 'Zvw-declaratie (wijkverpleging)', body: 'Volledige Zvw-declaratiestroom voor wijkverpleging — productcodes, prestaties, machtigingen en retourafhandeling per zorgverzekeraar.', status: 'live' },
      { icon: '📃', title: 'Zorginkoop & contractbeheer', body: 'Beheer van Wmo-/Jw-/Wlz-contracten met gemeenten en zorgkantoren — looptijden, productafspraken, tarieven en herziening-momenten.', status: 'live' },
    ],
  },
  {
    group: 'Planning & roosteren',
    intro: 'Van shift tot route, met CAO-engine die rust- en arbeidsregels bewaakt.',
    modules: [
      { icon: '📅', title: 'Shifts & Visits', body: 'Diensten, pauzes, ruil-verzoeken, zelfrooster en compensatie-saldi.', status: 'live' },
      { icon: '🗺️', title: 'Routing', body: 'Wijkroute-optimalisatie met reistijd en cliëntvoorkeuren.', status: 'live' },
      { icon: '⚖️', title: 'CAO-engine', body: 'CAO-regels gecodeerd; verzuim-aandachtspunten en wettelijke triggers.', status: 'live' },
      { icon: '🪜', title: 'Zelfrooster', body: 'Medewerkers kiezen eigen diensten binnen kaders — minder planner-werk, hogere tevredenheid.', status: 'live' },
      { icon: '⏱️', title: 'Tijdregistratie', body: 'Inklokken (mobiel/desktop), uren-verantwoording, automatische doorvoer naar loonrun en facturatie.', status: 'live' },
      { icon: '📱', title: 'Mobile-app (offline)', body: 'Veldwerk offline-first met sync; voor extramurale teams.', status: 'wip' },
      { icon: '🧩', title: 'Planhulp', body: 'AI-gestuurde planningsoptimalisatie en blokplanning-suggesties op basis van beschikbaarheid en cliëntvoorkeuren.', status: 'live' },
      { icon: '📐', title: 'Formatieplanning', body: 'Structurele bezettingsplanning op FTE-, team- en unit-niveau — los van shift-roostering, voor budget- en HR-cycli.', status: 'live' },
    ],
  },
  {
    group: 'Kwaliteit, HRM & portalen',
    intro: 'Kwaliteit-loop sluitend: meting, verbetering, registratie, gesprek.',
    modules: [
      { icon: '⚠️', title: 'VIM + Calamiteiten', body: 'Incidenten, calamiteiten, datalekken, PRISMA-analyse, leervoorstellen.', status: 'live' },
      { icon: '📣', title: 'Klachten (Wkkgz)', body: 'Volledige klachtenflow, geschilbehandeling, tijdlijn-events.', status: 'live' },
      { icon: '📈', title: 'Indicatoren', body: 'Versie-beheerde indicator-definities, aanleveringen en snapshots.', status: 'live' },
      { icon: '👤', title: 'HRM-uitbreiding', body: 'Bevoegdheden, deadlines, gesprekken, verzuim, contracten.', status: 'live' },
      { icon: '🏠', title: 'Cliënt-/familieportaal', body: 'Berichten, documenten, machtigingen, mantelzorger-taken.', status: 'live' },
      { icon: '💬', title: 'Berichten', body: 'Veilige interne berichtenuitwisseling tussen zorgmedewerkers — gecontextualiseerd per cliënt en team.', status: 'live' },
      { icon: '🤲', title: 'Vrijwilligers', body: 'Registratie van vrijwilligers, VOG-bewaking en inzet op activiteiten en dagbesteding.', status: 'live' },
      { icon: '🎓', title: 'Opleiding & competentiebeheer', body: 'BIG-herregistratie-bewaking, bijscholing, e-learning en competentie-matrix per functie — met automatische deadline-meldingen.', status: 'live' },
      { icon: '❤️', title: 'Engagement & medewerker-puls', body: 'Korte pulse-vragen, tevredenheid en signalen voor verloop-risico — voor managers en HR, niet voor toezicht.', status: 'live' },
      { icon: '🌱', title: 'WPM-rapportage (CO₂)', body: 'Werkgebonden Personenmobiliteit — jaarlijkse CO₂-mobiliteitsrapportage voor de RVO. Verplicht voor organisaties >100 medewerkers. Registreert woon-werkafstand, transportmiddel en thuiswerkpercentage per medewerker met SKAO/MVO-factoren; RVO-CSV-export ingebouwd.', status: 'live' },
    ],
  },
  {
    group: 'Integraties & ketenzorg',
    intro: 'Sindzo praat met het Nederlandse zorglandschap — geen lock-in.',
    modules: [
      { icon: '💊', title: 'Medicatie (intern)', body: 'Native medicatie-module — voorschriften, toedienregistratie, allergieën en interacties. Werkt standalone of in combinatie met Medimo-integratie.', status: 'live' },
      { icon: '🔗', title: 'Medimo-koppeling', body: 'Externe Medimo-koppeling voor organisaties die met Medimo werken — synchronisatie van toediening en voorschriften.', status: 'live' },
      { icon: '📨', title: 'ZorgMail', body: 'Veilige berichten en bijlagen via het ZorgMail-netwerk.', status: 'live' },
      { icon: '🔗', title: 'ZorgDomein', body: 'Verwijzingen en consultaties via ZorgDomein.', status: 'live' },
      { icon: '📦', title: 'BgZ & eOverdracht', body: 'BgZ-bundel met 8/15 Zibs actief; eOverdracht-Bundle-structuur gereed (resource-vulling volgt BgZ-completering). Nuts-aansluiting Q4 2026.', status: 'wip' },
      { icon: '🌐', title: 'MedMij + LSP', body: 'PGO-uitwisseling via MedMij en LSP-koppeling met opt-in.', status: 'wip' },
      { icon: '🧘', title: 'E-Health', body: 'Minddistrict, Therapieland, Embloom — blended care-flow.', status: 'wip' },
      { icon: '🏠', title: 'Domotica-gateway', body: 'Sensor- en alarmmeldingen van domotica-leveranciers (valdetectie, deurcontact, beweging) rechtstreeks in het dossier.', status: 'live' },
      { icon: '🔐', title: 'UZI-authenticatie', body: 'X.509-cert-ketenvalidatie tegen UZI-CA-bundel gereed. SAN-otherName-parsing wacht op CIBG-testcertificaat — verwacht Q3 2026, daarna productie-ready voor NEN 7510 en LSP-toegang.', status: 'wip' },
      { icon: '💳', title: 'Digitaal ondertekenen', body: 'iDIN of DocuSign voor zorgovereenkomsten, toestemmingsformulieren en digitale handtekeningen.', status: 'live' },
      { icon: '🏥', title: 'Ysis (Gerimedica)', body: 'Uitwisseling met Gerimedica Ysis voor gecombineerde verpleeghuis- en klinische zorg.', status: 'live' },
      { icon: '💰', title: 'Payroll-koppeling', body: 'Interface voor salarisverwerking — uren en toeslagen rechtstreeks naar uw payrollprovider.', status: 'wip' },
    ],
  },
  {
    group: 'AI & data',
    intro: 'AI als versneller — transparant, EU-conform, niet als black box.',
    modules: [
      { icon: '🎙️', title: 'Voice-rapportage', body: 'Web Speech API + AI-samenvatting, met audit-trail van bewerkingen.', status: 'live' },
      { icon: '🤖', title: 'AI-Matching', body: 'Cliënt ↔ professional matching met uitlegbare scoring.', status: 'wip' },
      { icon: '📚', title: 'CAO-RAG', body: 'CAO-uitleg via retrieval-augmented generation, met bronverwijzing.', status: 'wip' },
      { icon: '🚨', title: 'Fraud Detection', body: 'Patroon-herkenning op declaraties en planning.', status: 'wip' },
      { icon: '🔮', title: 'Predictive', body: 'Voorspelling van uitstroom, wachttijden en zorgintensiteit.', status: 'roadmap' },
      { icon: '⚡', title: 'Planningsassistent', body: 'Bij ziekmelding voert de assistent automatisch de hele keten uit: roostermutaties, cliëntnotificaties en taak-logging.', status: 'live' },
      { icon: '🩺', title: 'SOEP-Coach', body: 'LLM-laag boven de SOEP-editor: syndroomdetectie, Omaha-suggesties en automatische decursus-samenvatting — Anthropic met heuristische fallback.', status: 'live' },
    ],
  },
  {
    group: 'Compliance & regulatoir',
    intro: 'Niet alleen "voldoen aan" — actief begeleiden bij wet en deadlines.',
    modules: [
      { icon: '📜', title: 'Wtza-wizard', body: 'Toelating en jaarverantwoording (deadline 31 mei) met wizard-flow.', status: 'live' },
      { icon: '🛂', title: 'Wtta-uitleen', body: 'Uitlenersregistratie en automatische check — module beschikbaar 1 sep 2026, ruim vóór de wettelijke deadline 1 jan 2027.', status: 'wip' },
      { icon: '⚖️', title: 'Zelfstandigenwet', body: '€38/u rechtsvermoeden-toetsing en modelovereenkomst-engine.', status: 'live' },
      { icon: '🔒', title: 'NEN 7510', body: 'Control assessments, control-evidence en audit-export.', status: 'live' },
      { icon: '🏥', title: 'Wzd/Wvggz', body: 'Gedwongen zorg-registratie en halfjaarlijkse IGJ-XML.', status: 'live' },
      { icon: '🛡️', title: 'DPIA & verwerkingsregister', body: 'AVG art. 30/35-register met DPIA-beoordeling per verwerkingsactiviteit en sub-processor-overzicht.', status: 'live' },
      { icon: '📋', title: 'NEN 7513 audit-log', body: 'Onveranderbaar logboek van iedere toegang tot patiëntgegevens — vereist voor NEN 7510/7513 attest.', status: 'live' },
      { icon: '🔔', title: 'NIS2 incidentmeldplicht', body: 'Registratie, classificatie en melding van cyberbeveiligingsincidenten conform NIS2/Cbw.', status: 'live' },
      { icon: '🤖', title: 'AI Act-register', body: 'Classificatie en risicodocumentatie van AI-systemen conform de EU AI Act — vereist voor hoog-risico toepassingen.', status: 'live' },
      { icon: '📢', title: 'Klokkenluidersregeling (Wbk)', body: 'Wet bescherming klokkenluiders-flow voor organisaties >50 medewerkers — vertrouwelijk meldkanaal, behandeltermijnen en non-retaliatie-borging. Bewust gescheiden van VIM-incidenten.', status: 'live' },
      { icon: '🗳️', title: 'Cliëntenraad (WMCZ 2018)', body: 'Ondersteuning voor wettelijk verplichte cliëntenraad bij >25 cliënten: adviesaanvragen, instemmingsrecht-procedures, jaarverslag en raadsleden-administratie.', status: 'live' },
    ],
  },
  {
    group: 'Welzijn medewerker — uniek in NL',
    intro: 'Wat geen NL-concurrent biedt (marktscan 2026-05-29): peer-support tussen collega\'s, strikt gescheiden van HR. Buitenlands bewijs voor retentie-effect (NHS RISE: +20%).',
    modules: [
      { icon: '🤝', title: 'Collega-netwerk (buddy + intervisie)', body: 'Zelf-aanmelden voor onboarding-buddy, internationale-instroom-buddy, intervisie- of sparring-partner. Regelgebaseerde matching op thema, taal en beschikbaarheid. Geen welzijns-/gezondheidsdata in fase 1 — geen HR-inzage.', status: 'live' },
      { icon: '🌍', title: 'Internationale-instroom-buddy', body: 'Hardgecodeerde meertalige UI (NL/EN/TR/AR/PL/UK) vanaf dag 1, zodat internationaal geworven verpleegkundigen direct in eigen taal werken.', status: 'live' },
      { icon: '💬', title: 'Lotgenoten-support (vertrouwelijk)', body: 'Anoniem aanmelden op welzijnsthema (werkdruk, burn-out, rouw na incident, mantelzorg, re-integratie) met besloten 1-op-1-kanaal. Crisis-escalatie naar Vertrouwenspersoon — nooit HR. DPIA afgerond.', status: 'live' },
    ],
  },
  {
    group: 'Inzicht & rapportage',
    intro: 'Bestuur, raad van toezicht en management krijgen één bron-van-waarheid — geen export-naar-Excel-rituelen meer.',
    modules: [
      { icon: '📊', title: 'BI-dashboard', body: 'Vooraf-gedefinieerde KPI-dashboards voor zorg, financiën, HR en compliance — drilldown naar bron-record, geen losse rapportage-tool nodig.', status: 'live' },
      { icon: '📈', title: 'Sector-benchmarks', body: 'Vergelijk uw KPI\'s met geanonimiseerde sectorgemiddelden (verzuim, caseload, declaratie-doorlooptijd) — opt-in, met expliciete privacy-toestemming.', status: 'live' },
    ],
  },
];
---
<Base
  title="Oplossing — modulaire zorgsuite | Sindzo"
  description="Acht groepen modules: ECD, declaratie, planning, kwaliteit, integraties, AI, compliance en BI. Modulair activeerbaar, FHIR R4, NL-hosting, eerlijke status per module."
  image="/og/oplossing.png"
>
  <PageHero
    eyebrow="Oplossing"
    title="Eén zorgsuite, modulair geactiveerd."
    subtitle="Sindzo is geen logge monoliet en geen losse verzameling best-of-breed-tools. Het is één modulair platform: u activeert alleen wat u nodig hebt, het deelt één dossier en één identiteit, en u groeit mee zonder migratie."
  >
    <div slot="actions" class="flex flex-wrap gap-3">
      <a href="/demo" class="btn-primary no-underline">Demo aanvragen</a>
      <a href="/integraties" class="btn-secondary no-underline">Naar integraties</a>
    </div>
  </PageHero>

  <ProductMockups />

  <section class="border-b border-ink-100 bg-ink-100/40 py-10">
    <div class="container-prose grid grid-cols-2 gap-6 text-center sm:grid-cols-4">
      <div>
        <div class="font-display text-3xl font-bold text-sindzo-700">8 groepen</div>
        <div class="mt-1 text-xs text-ink-500">Modules per functiegebied</div>
      </div>
      <div>
        <div class="font-display text-3xl font-bold text-sindzo-700">4 plannen</div>
        <div class="mt-1 text-xs text-ink-500">Basic · Pro · Plus · Enterprise</div>
      </div>
      <div>
        <div class="font-display text-3xl font-bold text-sindzo-700">FHIR R4</div>
        <div class="mt-1 text-xs text-ink-500">Open API</div>
      </div>
      <div>
        <div class="font-display text-3xl font-bold text-sindzo-700">.NET 10</div>
        <div class="mt-1 text-xs text-ink-500">Moderne stack, NL-hosting</div>
      </div>
    </div>
  </section>

  {groups.map((g) => (
    <section class="container-prose py-16 border-b border-ink-100 last:border-0">
      <div class="max-w-3xl">
        <h2 class="font-display text-2xl font-bold text-ink-900 sm:text-3xl">{g.group}</h2>
        <p class="mt-2 text-ink-700">{g.intro}</p>
      </div>
      <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {g.modules.map((m) => (
          <ModuleCard
            icon={m.icon}
            title={m.title}
            body={m.body}
            features={m.features}
            status={m.status}
          />
        ))}
      </div>
    </section>
  ))}

  <RelatedArticles
    title="Diepgaande achtergrond bij de white-space-modules"
    intro="De Welzijn-modulegroep en het meertalig cliëntportaal zijn onze sterkste differentiators. Hier de feitelijke onderbouwing waarop ze rusten — bronnen en marktscan inbegrepen."
    articles={[
      {
        eyebrow: 'Standaarden + marktanalyse',
        title: 'Waarom geen NL-VVT/GHZ-leverancier meertalig is',
        body: 'Marktscan van 9 cliëntportalen. Wat de demografie eist en waarom niemand het tot nu toe deed.',
        href: '/kennisbank/meertalig-clientportaal-nl-zorg',
      },
      {
        eyebrow: 'Arbeidsmarkt + welzijn',
        title: 'Peer-support voor zorgmedewerkers — wat het onderzoek echt zegt',
        body: 'NHS RISE rapporteert +20% retentie. Hier waarom geen NL-werkgever het aanbiedt en hoe HR-scheiding in code werkt.',
        href: '/kennisbank/peer-support-zorgmedewerkers',
      },
    ]}
  />

  <Cta />
</Base>
