# Cloudflare Pages headers-config. Wordt automatisch toegepast bij elke
# request, parallel aan onze .htaccess (die alleen relevant is voor Plesk).
# Cloudflare bedient de marketingsite via deze regels.

# ----- Globaal: security headers -----
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# ----- Fingerprinted assets — far-future cache + immutable -----
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# ----- Fonts — far-future cache -----
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# ----- OG-images en favicon kunnen 1 week cachen -----
/og/*
  Cache-Control: public, max-age=604800
/favicon.svg
  Cache-Control: public, max-age=604800

# ----- HTML: korte cache, must-revalidate (snelle deploys zichtbaar) -----
/*.html
  Cache-Control: public, max-age=0, must-revalidate
