---
// Kruislink naar relevante kennisbank-artikelen. Mount op pagina's waar
// de USP-context past, zodat lezers naar diepere content kunnen door­klikken.

interface Article { title: string; body: string; href: string; eyebrow: string; }

interface Props {
  title?: string;
  intro?: string;
  articles: Article[];
}

const {
  title = 'Verder lezen in de kennisbank',
  intro = 'Achtergrond bij wat hierboven staat — gesourcet, vrij toegankelijk.',
  articles,
} = Astro.props;
---
<section class="container-prose py-14 border-t border-ink-100">
  <div class="max-w-2xl mb-8">
    <span class="eyebrow">Kennisbank</span>
    <h2 class="mt-3 font-display text-2xl font-bold text-ink-900 sm:text-3xl">{title}</h2>
    <p class="mt-3 text-sm text-ink-700">{intro}</p>
  </div>
  <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {articles.map((a) => (
      <li>
        <a href={a.href} class="group block rounded-xl border border-ink-100 bg-white p-5 no-underline transition hover:border-sindzo-300 hover:shadow-sm">
          <span class="text-[10px] uppercase tracking-wider font-bold text-accent-700">{a.eyebrow}</span>
          <h3 class="mt-2 font-display text-base font-semibold text-ink-900 group-hover:text-sindzo-700 transition">{a.title}</h3>
          <p class="mt-2 text-sm text-ink-700 leading-snug">{a.body}</p>
          <span class="mt-3 inline-block text-xs font-semibold text-sindzo-700">Lees het artikel →</span>
        </a>
      </li>
    ))}
  </ul>
</section>
