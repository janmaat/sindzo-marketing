---
import Base from './Base.astro';
import PageHero from '../components/PageHero.astro';
import Cta from '../components/Cta.astro';

interface Trigger { title: string; body: string; }
interface Module { name: string; note: string; }
interface ProofPoint { value: string; label: string; }

interface Props {
  segmentKey: string;       // 'vvt' | 'ghz' | 'ggz' | 'huisartsen'
  segmentLabel: string;     // 'VVT'
  title: string;            // Pagina-titel (SEO)
  eyebrow: string;          // "Voor VVT-organisaties"
  hero: string;             // hero h1
  subtitle: string;         // hero subtitle
  triggers: Trigger[];      // 3-4 doelgroep-pijnpunten
  modules: Module[];        // 6-8 modules die het meest van toepassing zijn
  regulatory: string[];     // relevante wetten
  proofPoints?: ProofPoint[];
  caseQuote?: { quote: string; author: string; org: string };
  image?: string;         // og:image-pad voor deze segmentpagina
}

const {
  title, eyebrow, hero, subtitle,
  triggers, modules, regulatory, proofPoints, caseQuote, image,
} = Astro.props;
---
<Base title={title} image={image}>
  <PageHero eyebrow={eyebrow} title={hero} subtitle={subtitle}>
    <div slot="actions" class="flex flex-wrap gap-3">
      <a href="/demo" class="btn-primary no-underline">Demo aanvragen</a>
      <a href="/oplossing" class="btn-secondary no-underline">Bekijk modules</a>
    </div>
  </PageHero>

  {proofPoints && (
    <section class="border-b border-ink-100 bg-ink-100/40">
      <div class="container-prose py-10 grid grid-cols-2 gap-6 sm:grid-cols-4">
        {proofPoints.map((p) => (
          <div>
            <div class="font-display text-3xl font-bold text-sindzo-700">{p.value}</div>
            <div class="mt-1 text-xs text-ink-500">{p.label}</div>
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="container-prose py-20">
    <div class="max-w-2xl">
      <h2 class="font-display text-3xl font-bold tracking-tightish text-ink-900">Wat zien wij in deze sector?</h2>
      <p class="mt-3 text-ink-700">
        De aanleiding voor vervanging is zelden één feature. Het zijn drie of vier patronen tegelijk.
      </p>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {triggers.map((t) => (
        <div class="rounded-xl border border-ink-100 bg-white p-6">
          <h3 class="font-display text-lg font-semibold text-ink-900">{t.title}</h3>
          <p class="mt-2 text-sm text-ink-700 leading-relaxed">{t.body}</p>
        </div>
      ))}
    </div>
  </section>

  {caseQuote && (
    <section class="bg-sindzo-50/50 border-y border-sindzo-100">
      <div class="container-prose py-16">
        <blockquote class="max-w-3xl">
          <p class="font-display text-xl sm:text-2xl leading-relaxed text-ink-900">
            "{caseQuote.quote}"
          </p>
          <footer class="mt-6 text-sm text-ink-500">
            <span class="font-semibold text-ink-700">{caseQuote.author}</span> · {caseQuote.org}
          </footer>
        </blockquote>
      </div>
    </section>
  )}

  <section class="container-prose py-20">
    <div class="grid gap-10 lg:grid-cols-[280px_1fr]">
      <div>
        <h2 class="font-display text-3xl font-bold tracking-tightish text-ink-900">Modules die hier het meest waarde geven</h2>
        <p class="mt-3 text-sm text-ink-700">
          Activeer alleen wat u nodig hebt. Schaal mee zonder migratiepijn.
        </p>
        <a href="/oplossing" class="mt-5 inline-block text-sm font-medium text-sindzo-700 no-underline hover:underline">
          Volledige modulekaart →
        </a>
      </div>
      <ul class="grid gap-3 sm:grid-cols-2">
        {modules.map((m) => (
          <li class="rounded-lg border border-ink-100 bg-white p-4">
            <div class="font-semibold text-sm text-ink-900">{m.name}</div>
            <div class="mt-1 text-xs text-ink-500">{m.note}</div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="container-prose py-12 border-t border-ink-100">
    <h3 class="font-display text-xl font-semibold text-ink-900">Relevante wettelijke kaders</h3>
    <p class="mt-2 text-sm text-ink-700 max-w-2xl">
      Sindzo volgt deze actief — geen "we kijken er nog naar" als de deadline al voorbij is.
      Status per kader op het <a href="/trust" class="text-sindzo-700 hover:underline">Trust Centre</a>.
    </p>
    <ul class="mt-5 flex flex-wrap gap-2">
      {regulatory.map((r) => (
        <li class="badge">{r}</li>
      ))}
    </ul>
  </section>

  <Cta
    title="Wilt u een demo op uw eigen werkprocessen?"
    subtitle="Stuur drie typische werkstromen uit uw organisatie. Wij laten zien hoe Sindzo ze ondersteunt — geen scripted pitch."
  />
</Base>
