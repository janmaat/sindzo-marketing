---
import SegmentLayout from '../../layouts/SegmentLayout.astro';
---
<SegmentLayout
  image="/og/voor-vvt.png"
  segmentKey="vvt"
  segmentLabel="VVT"
  title="VVT-software — verpleging, verzorging, thuiszorg | Coheza"
  eyebrow="Voor VVT-organisaties"
  hero="Eén platform voor intra- en extramurale zorg — gebouwd voor arbeidskrapte."
  subtitle="Coheza combineert ECD, planning, declaratie en kwaliteit in één werkproces. Geen schakelen tussen systemen, geen dubbele invoer, geen tijd verliezen aan administratie die niet bijdraagt aan zorg."
  triggers={[
    { title: 'Arbeidsmarktkrapte', body: 'ActiZ verwacht structurele tekorten tot 2030. Coheza verlaagt de admin-last per dienst zodat zorgmedewerkers meer tijd aan cliënten besteden — én blijven.' },
    { title: 'Intra- vs. extramurale versnippering', body: 'Eén dossier voor verpleeghuis én wijk. Eén identiteit per cliënt, één route, één rapportage — ongeacht waar zorg geleverd wordt.' },
    { title: 'Regeldruk via ECD', body: 'Zorg voor Beter: 18% van de admin-last hangt samen met het ECD. Coheza dringt dat terug met SOEP-pre-fill, spraak-rapportage en logische dossierstructuur.' },
    { title: 'eOverdracht & Wegiz', body: 'BgZ-conforme overdracht naar ziekenhuis, huisarts of vervolgzorg — zonder PDF-printen-en-faxen, klaar voor de Wegiz-verplichting.' },
    { title: 'Diverse cliëntenpopulatie', body: 'De 1e-generatie Turkse en Marokkaanse VVT-cliënten beheersen vaak onvoldoende Nederlands voor formele portaal-teksten. Coheza Naast is in 7 talen (NL/EN/TR/AR/DE + PL/UK) — uniek in NL-VVT volgens onze marktscan (mei 2026).' },
  ]}
  modules={[
    { name: 'Cliëntdossier + zorgplan', note: 'Omaha + episode of care, BSN-encrypted' },
    { name: 'SOEP-rapportage met voice', note: 'Pre-fill + spraak voor wijkverpleegkundige' },
    { name: 'Zelfrooster', note: 'Medewerkers kiezen eigen diensten binnen CAO-kaders' },
    { name: 'Tijdregistratie', note: 'Mobiel inklokken, door naar loonrun en facturatie' },
    { name: 'Routing & wijkroutes', note: 'Optimalisatie met cliëntvoorkeuren' },
    { name: 'CAO-engine', note: 'ATW/ATV-regels gecodeerd, automatische triggers' },
    { name: 'eOverdracht', note: 'BgZ-conform, Wegiz-aansluiting in afronding' },
    { name: 'Medicatie via Medimo', note: 'Voorschrift → toedienregistratie' },
    { name: 'iWmo + Productie + Budget', note: 'Volledige Wmo-flow + budgetbewaking' },
    { name: 'Familieportaal', note: 'Mantelzorger-taken, foto\'s, berichten' },
    { name: 'Meertalig cliëntportaal', note: 'NL/EN/TR/AR/DE + PL/UK — geen NL-concurrent biedt dit' },
    { name: 'Collega-netwerk (welzijn)', note: 'Buddy/intervisie matching — strikt gescheiden van HR' },
  ]}
  regulatory={['Wkkgz', 'Wtza', 'AVG', 'NEN 7510', 'Wegiz', 'Wzd (extramurale toepassing)']}
  proofPoints={[
    { value: 'NL', label: 'Hosting (Azure West-EU) + Nederlandstalig team' },
    { value: '1×', label: 'Inloggen — alle modules in één werkruimte' },
    { value: 'FHIR', label: 'Open standaard voor uitwisseling' },
    { value: '24/7', label: 'Audit-logging onveranderbaar bewaard' },
  ]}
/>
